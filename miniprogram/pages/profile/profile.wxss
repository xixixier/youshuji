/* pages/profile/profile.wxss */
page {
  background-color: var(--fluent-bg);
  padding-bottom: 80rpx;
}

.container {
  padding: 0;
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
}

/* ==========================================
   1. 微软 Fluent 风格账户看板 (Fluent Account Showcase)
   ========================================== */
.account-showcase-panel {
  background-color: var(--fluent-surface);
  border-bottom: 1rpx solid var(--fluent-divider);
  padding: 48rpx 32rpx;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

/* 未登录状态样式 */
.unlogin-box {
  display: flex;
  align-items: center;
  gap: 24rpx;
  width: 100%;
}

.circle-avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: #F3F4F6;
  border: 1rpx solid var(--fluent-divider);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.account-meta-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.account-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--fluent-text-main);
}

.account-subtitle {
  font-size: 22rpx;
  color: var(--fluent-text-mute);
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.fluent-mini-btn {
  background-color: var(--fluent-primary) !important;
  color: var(--fluent-surface) !important;
  font-size: 22rpx !important;
  font-weight: 600 !important;
  padding: 12rpx 28rpx !important;
  border-radius: 6rpx !important;
  width: auto !important;
  margin: 0 !important;
  line-height: 1.4 !important;
}

/* 已登录状态样式 */
.logged-box {
  display: flex;
  align-items: center;
  gap: 24rpx;
  width: 100%;
}

.circle-avatar-logged {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: var(--fluent-primary-light);
  color: var(--fluent-primary);
  font-size: 40rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(16, 124, 65, 0.2);
  flex-shrink: 0;
}

.account-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.account-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--fluent-text-main);
  max-width: 260rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sync-badge-active {
  font-size: 18rpx;
  font-weight: 700;
  color: var(--fluent-primary);
  background-color: var(--fluent-primary-light);
  padding: 4rpx 10rpx;
  border-radius: 4rpx;
  border: 1rpx solid rgba(16, 124, 65, 0.15);
}

.account-id-text {
  font-size: 22rpx;
  color: var(--fluent-text-mute);
  font-weight: 500;
}

.account-action-link {
  font-size: 22rpx;
  color: var(--fluent-danger);
  font-weight: 600;
  margin-top: 4rpx;
  display: inline-block;
}

/* ==========================================
   2. 设置栏分区标题 (Settings Section Header)
   ========================================== */
.settings-section-title {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--fluent-text-mute);
  padding: 16rpx 32rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  width: 100%;
  box-sizing: border-box;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--fluent-text-sec);
  font-weight: 500;
}

/* ==========================================
   3. 三合一高保真登录抽屉 (Login Drawer Overlay)
   ========================================== */
.drawer-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.drawer-panel {
  background-color: var(--fluent-surface);
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
  padding: 40rpx 40rpx 60rpx;
  width: 100%;
  box-sizing: border-box;
  animation: slideUp 0.3s cubic-bezier(0.1, 0.9, 0.2, 1);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.drawer-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--fluent-text-main);
  letter-spacing: 0.5rpx;
}

.drawer-close-btn {
  font-size: 36rpx;
  color: var(--fluent-text-mute);
  padding: 10rpx;
}

.drawer-tabs {
  display: flex;
  border-bottom: 2rpx solid var(--fluent-divider);
  margin-bottom: 40rpx;
}

.drawer-tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--fluent-text-mute);
  position: relative;
  transition: all 0.2s ease;
}

.drawer-tab-item.active {
  color: var(--fluent-primary);
  font-weight: 700;
}

.drawer-tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 30rpx;
  right: 30rpx;
  height: 4rpx;
  background-color: var(--fluent-primary);
  border-radius: 2rpx;
}

.tab-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  animation: fadeIn 0.2s ease;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.wechat-preview-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  text-align: center;
}

.login-tip {
  font-size: 24rpx;
  color: var(--fluent-text-sec);
  line-height: 1.6;
  max-width: 500rpx;
}

.fluent-login-btn {
  width: 100% !important;
  background-color: var(--fluent-primary);
  color: var(--fluent-surface);
  font-size: 28rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.fluent-login-btn.wechat-theme {
  background-color: #07C160;
}

.form-slot {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
  margin-bottom: 40rpx;
}

.input-row {
  display: flex;
  align-items: center;
  border: 1px solid var(--fluent-divider);
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  background-color: #FAF9F9;
  width: 100%;
  box-sizing: border-box;
}

.input-icon {
  margin-right: 16rpx;
}

.drawer-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--fluent-text-main);
  height: 48rpx;
}

.sms-send-btn {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--fluent-primary);
  background-color: var(--fluent-primary-light);
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
}

.sms-send-btn.counting {
  color: var(--fluent-text-mute);
  background-color: #EFEFEF;
}

.drawer-footer-note {
  font-size: 20rpx;
  color: var(--fluent-text-mute);
  text-align: center;
  margin-top: 32rpx;
}
