/* pages/profile/profile.wxss */
page {
  background-color: var(--color-canvas);
  padding-bottom: 80rpx;
}

.container {
  padding: 0;
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
}

/* ==========================================
   1. 账户看板 (Account Showcase Panel)
   ========================================== */
.account-showcase-panel {
  background-color: var(--color-surface);
  border-bottom: 1rpx solid var(--color-divider-solid);
  padding: var(--sp-xl) var(--sp-lg);
  width: 100%;
  box-sizing: border-box;
  margin-bottom: var(--sp-md);
}

/* 未登录状态 */
.unlogin-box {
  display: flex;
  align-items: center;
  gap: var(--sp-md);
  width: 100%;
}

.circle-avatar-placeholder {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background-color: var(--color-canvas);
  border: 1rpx solid var(--color-divider-solid);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.circle-avatar-placeholder .icon-user {
  opacity: 0.7;
}

.account-meta-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--sp-xs);
  min-width: 0;
}

.account-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-1);
  line-height: 1.3;
}

.account-subtitle {
  font-size: 22rpx;
  color: var(--color-text-3);
  font-weight: 400;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.fluent-mini-btn {
  background-color: var(--color-primary) !important;
  color: #FFFFFF !important;
  font-size: 22rpx !important;
  font-weight: 600 !important;
  padding: 10rpx 24rpx !important;
  border-radius: var(--radius-pill) !important;
  width: auto !important;
  margin: 0 !important;
  line-height: 1.4 !important;
  flex-shrink: 0;
}

/* 已登录状态 */
.logged-box {
  display: flex;
  align-items: center;
  gap: var(--sp-md);
  width: 100%;
}

.circle-avatar-logged {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background-color: var(--color-primary-soft);
  color: var(--color-primary);
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1.5rpx solid var(--color-primary-mist);
  flex-shrink: 0;
}

.account-name-row {
  display: flex;
  align-items: center;
  gap: var(--sp-sm);
}

.account-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-1);
  max-width: 280rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.3;
}

.sync-badge-active {
  font-size: 18rpx;
  font-weight: 600;
  color: var(--color-primary);
  background-color: var(--color-primary-soft);
  padding: 4rpx 10rpx;
  border-radius: var(--radius-xs);
  line-height: 1.3;
}

.account-id-text {
  font-size: 22rpx;
  color: var(--color-text-3);
  font-weight: 400;
  line-height: 1.4;
}

.account-action-link {
  font-size: 22rpx;
  color: var(--color-danger);
  font-weight: 500;
  margin-top: 4rpx;
  display: inline-block;
  line-height: 1.4;
}

/* ==========================================
   2. 设置栏分区标题 (Settings Section Header)
   ========================================== */
.settings-section-title {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--color-text-3);
  padding: var(--sp-sm) var(--sp-lg);
  text-transform: uppercase;
  letter-spacing: 1rpx;
  line-height: 1.2;
  width: 100%;
  box-sizing: border-box;
}

/* 菜单行图标间距 */
.menu-icon {
  margin-right: var(--sp-md);
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-2);
  font-weight: 500;
  line-height: 1.4;
}

/* ==========================================
   3. 三合一登录抽屉 (Login Drawer Overlay)
   ========================================== */
.drawer-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(15, 23, 42, 0.4);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.drawer-panel {
  background-color: var(--color-surface);
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  padding: 40rpx 36rpx 60rpx;
  width: 100%;
  box-sizing: border-box;
  animation: slideUp 0.3s cubic-bezier(0.1, 0.9, 0.2, 1);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--sp-lg);
}

.drawer-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-1);
  line-height: 1.3;
}

.drawer-close-btn {
  font-size: 32rpx;
  color: var(--color-text-3);
  padding: 10rpx;
  line-height: 1;
}

.drawer-tabs {
  display: flex;
  border-bottom: 1rpx solid var(--color-divider-solid);
  margin-bottom: var(--sp-lg);
}

.drawer-tab-item {
  flex: 1;
  text-align: center;
  padding: var(--sp-sm) 0;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-3);
  position: relative;
  transition: all 0.2s ease;
}

.drawer-tab-item.active {
  color: var(--color-primary);
  font-weight: 700;
}

.drawer-tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -1rpx;
  left: 30rpx;
  right: 30rpx;
  height: 3rpx;
  background-color: var(--color-primary);
  border-radius: 2rpx;
}

.tab-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.wechat-preview-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--sp-lg) var(--sp-sm);
  text-align: center;
}

.wechat-icon-hero {
  margin-bottom: var(--sp-md);
}

.login-tip {
  font-size: 24rpx;
  color: var(--color-text-2);
  line-height: 1.6;
  max-width: 500rpx;
}

.fluent-login-btn {
  width: 100% !important;
  height: 92rpx;
  background-color: var(--color-primary) !important;
  color: #FFFFFF !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
  padding: 0 !important;
  border-radius: var(--radius-pill) !important;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  line-height: 1;
}

.fluent-login-btn.wechat-theme {
  background-color: var(--color-wechat) !important;
}

.wechat-btn-icon {
  margin-right: var(--sp-sm);
}

.form-slot {
  display: flex;
  flex-direction: column;
  gap: var(--sp-md);
  width: 100%;
  margin-bottom: var(--sp-lg);
}

.input-row {
  display: flex;
  align-items: center;
  border: 1rpx solid var(--color-divider-solid);
  border-radius: var(--radius-sm);
  padding: var(--sp-sm) var(--sp-md);
  background-color: var(--color-canvas);
  width: 100%;
  box-sizing: border-box;
}

.input-icon {
  margin-right: var(--sp-sm);
}

.drawer-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text-1);
  height: 48rpx;
  line-height: 48rpx;
}

.sms-send-btn {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-primary);
  background-color: var(--color-primary-soft);
  padding: var(--sp-xs) var(--sp-sm);
  border-radius: var(--radius-xs);
  flex-shrink: 0;
}

.sms-send-btn.counting {
  color: var(--color-text-3);
  background-color: var(--color-canvas);
}

.drawer-footer-note {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  color: var(--color-text-3);
  text-align: center;
  margin-top: var(--sp-lg);
  line-height: 1.2;
}
