/* pages/profile/profile.wxss — 有数记 · 个人中心高订版面 */

page {
  background-color: var(--color-canvas);
  padding-bottom: 120rpx;
}

.container {
  padding: 0;
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
}

/* ==========================================
   1. 名片式账户面板 (Luxury Showcase Card)
   ========================================== */
.account-showcase-panel {
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  margin: var(--sp-md) var(--sp-lg);
  padding: 44rpx var(--sp-lg);
  box-sizing: border-box;
  box-shadow: var(--shadow-organic);
  border: 1rpx solid rgba(28, 61, 50, 0.04);
  position: relative;
  overflow: hidden;
}

/* 增加名片背景纹理 */
.account-showcase-panel::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at 100% 100%, var(--color-accent-soft) 0%, transparent 60%);
  opacity: 0.5;
  pointer-events: none;
}

/* 未登录状态 */
.unlogin-box {
  display: flex;
  align-items: center;
  gap: var(--sp-md);
  width: 100%;
  position: relative;
  z-index: 2;
}

.circle-avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: var(--color-canvas);
  border: 1rpx solid var(--color-divider-solid);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.circle-avatar-placeholder .icon {
  opacity: 0.7;
}

.account-meta-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.account-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-1);
  letter-spacing: 0.5rpx;
}

.account-subtitle {
  font-size: 22rpx;
  color: var(--color-text-3);
  font-weight: 500;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fluent-mini-btn {
  background-color: var(--color-primary) !important;
  color: #FFFFFF !important;
  font-size: 22rpx !important;
  font-weight: 700 !important;
  padding: 12rpx 28rpx !important;
  border-radius: var(--radius-pill) !important;
  width: auto !important;
  margin: 0 !important;
  line-height: normal !important;
  flex-shrink: 0;
  box-shadow: 0 4px 12px rgba(28, 61, 50, 0.12);
  letter-spacing: 1rpx;
}

/* 已登录状态 */
.logged-box {
  display: flex;
  align-items: center;
  gap: var(--sp-md);
  width: 100%;
  position: relative;
  z-index: 2;
}

.circle-avatar-logged {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: var(--color-primary-soft);
  color: var(--color-primary);
  font-family: var(--font-serif);
  font-size: 40rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1.5rpx solid rgba(28, 61, 50, 0.08);
  flex-shrink: 0;
}

.account-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.account-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-1);
  margin-right: 12rpx;
  letter-spacing: 0.5rpx;
}

.sync-badge-active {
  font-size: 16rpx;
  font-weight: 700;
  color: var(--color-primary);
  background-color: var(--color-primary-soft);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-xs);
  letter-spacing: 0.5rpx;
}

.account-id-text {
  font-size: 20rpx;
  color: var(--color-text-3);
  font-weight: 500;
  margin-top: 6rpx;
}

.account-action-link {
  font-size: 22rpx;
  color: var(--color-danger);
  font-weight: 700;
  margin-top: 10rpx;
  letter-spacing: 0.5rpx;
  display: inline-block;
}

/* ==========================================
   2. 琴键式设置列表栏 (Menu List Section)
   ========================================== */
.settings-section-title {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--color-text-3);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin: var(--sp-md) var(--sp-lg) var(--sp-xs);
  padding-left: var(--sp-xs);
}

.fluent-list {
  display: flex;
  flex-direction: column;
  background-color: var(--color-surface);
  border-radius: var(--radius-md);
  margin: 0 var(--sp-lg) var(--sp-md);
  box-shadow: 0 4px 16px rgba(28, 61, 50, 0.015);
  border: 1rpx solid rgba(28, 61, 50, 0.03);
  overflow: hidden;
}

.fluent-item {
  display: flex;
  align-items: center;
  padding: 0 var(--sp-lg);
  height: 104rpx;
  border-bottom: 1rpx solid var(--color-divider);
  box-sizing: border-box;
  transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.fluent-item:last-child {
  border-bottom: none;
}

.menu-icon {
  margin-right: var(--sp-md);
  width: 44rpx;
  height: 44rpx;
  opacity: 0.8;
}

.menu-text {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-2);
  letter-spacing: 0.5rpx;
}

.fluent-item .icon-arrow {
  opacity: 0.5;
}

/* ==========================================
   3. 高订手持式登录抽屉 (Login Drawer Sheet)
   ========================================== */
.drawer-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(25, 30, 28, 0.4);
  backdrop-filter: blur(8px);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.drawer-panel {
  width: 100%;
  background-color: var(--color-surface);
  border-top-left-radius: var(--radius-lg);
  border-top-right-radius: var(--radius-lg);
  padding: 48rpx 40rpx 72rpx;
  box-sizing: border-box;
  animation: slideUp 0.3s cubic-bezier(0.25, 0.8, 0.25, 1) forwards;
  box-shadow: 0 -8px 32px rgba(28, 61, 50, 0.05);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--sp-lg);
}

.drawer-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 1.5rpx;
}

.drawer-close-btn {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-3);
  padding: var(--sp-xs);
}

.drawer-tabs {
  display: flex;
  border-bottom: 1rpx solid var(--color-divider);
  margin-bottom: var(--sp-lg);
}

.drawer-tab-item {
  padding: 16rpx 0;
  margin-right: 48rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-3);
  position: relative;
}

.drawer-tab-item.active {
  color: var(--color-primary);
}

.drawer-tab-item.active::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: 0;
  width: 100%;
  height: 4rpx;
  background-color: var(--color-primary);
  border-radius: var(--radius-pill);
}

.tab-content {
  display: flex;
  flex-direction: column;
  margin-bottom: var(--sp-lg);
}

.wechat-preview-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  text-align: center;
}

.wechat-icon-hero {
  margin-bottom: 24rpx;
}

.login-tip {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-2);
  line-height: 1.6;
  max-width: 480rpx;
}

.fluent-login-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-primary);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  height: 92rpx;
  border-radius: var(--radius-pill);
  box-shadow: 0 8px 24px rgba(28, 61, 50, 0.15);
  letter-spacing: 1.5rpx;
}

.wechat-theme {
  background-color: var(--color-primary);
}

.wechat-btn-icon {
  margin-right: 12rpx;
}

/* 表单输入域 */
.form-fields {
  display: flex;
  flex-direction: column;
  gap: var(--sp-md);
  margin-bottom: var(--sp-lg);
}

.field-row {
  display: flex;
  align-items: center;
  height: 92rpx;
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-divider-solid);
  background-color: var(--color-canvas);
  padding: 0 var(--sp-md);
  box-sizing: border-box;
}

.field-icon {
  margin-right: var(--sp-sm);
}

.field-input {
  flex: 1;
  height: 100%;
  font-size: 26rpx;
  color: var(--color-text-1);
  font-weight: 600;
}

.sms-btn {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-accent);
  padding: var(--sp-xs) var(--sp-sm);
}

.sms-disabled {
  color: var(--color-text-3);
}

.drawer-footer {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: var(--color-text-3);
  letter-spacing: 0.5rpx;
  margin-top: var(--sp-md);
}
