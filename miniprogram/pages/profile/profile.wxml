<!--pages/profile/profile.wxml-->
<view class="container">

  <!-- 1. 账户看板 (Account Showcase Panel) -->
  <view class="account-showcase-panel">

    <!-- 未登录状态看板 -->
    <view class="unlogin-box" wx:if="{{!hasLogin}}" bindtap="triggerLoginAction">
      <view class="circle-avatar-placeholder">
        <view class="icon icon-lg icon-user"></view>
      </view>
      <view class="account-meta-text">
        <text class="account-title">暂未开启账户同步</text>
        <text class="account-subtitle">点击登录，保护您的账本数据安全</text>
      </view>
      <button class="fluent-mini-btn" hover-class="press-active">立即登录</button>
    </view>

    <!-- 已登录状态看板 -->
    <view class="logged-box" wx:else>
      <view class="circle-avatar-logged">
        {{userInfo.firstChar || '数'}}
      </view>
      <view class="account-meta-text">
        <view class="account-name-row">
          <text class="account-name">{{userInfo.nickName || '有数用户'}}</text>
          <view class="sync-badge-active">云端已同步</view>
        </view>
        <text class="account-id-text">数据安全存储加密中 · 微信云开发平台</text>
        <text class="account-action-link" bindtap="handleLogout">退出 / 切换同步账号</text>
      </view>
    </view>

  </view>

  <!-- 2. 设置列表 (Settings Groups) -->

  <view class="settings-section-title">应用同步与参数</view>
  <view class="fluent-list">
    <view class="fluent-item" bindtap="navigateTo" data-url="/pages/settings/reminder" hover-class="press-active">
      <view class="icon icon-settings menu-icon"></view>
      <text class="menu-text">续费提醒设置</text>
      <view class="icon icon-sm icon-arrow"></view>
    </view>
    <view class="fluent-item" bindtap="navigateTo" data-url="/pages/settings/backup" hover-class="press-active">
      <view class="icon icon-backup menu-icon"></view>
      <text class="menu-text">云端数据备份与下载</text>
      <view class="icon icon-sm icon-arrow"></view>
    </view>
  </view>

  <view class="settings-section-title">实用工具与数据</view>
  <view class="fluent-list">
    <view class="fluent-item" bindtap="loadSampleData" hover-class="press-active">
      <view class="icon icon-sync menu-icon"></view>
      <text class="menu-text">一键注入预置示例账单</text>
      <view class="icon icon-sm icon-arrow"></view>
    </view>
    <view class="fluent-item" bindtap="navigateTo" data-url="/pages/help/index" hover-class="press-active">
      <view class="icon icon-help menu-icon"></view>
      <text class="menu-text">帮助手册与反馈</text>
      <view class="icon icon-sm icon-arrow"></view>
    </view>
    <view class="fluent-item" bindtap="navigateTo" data-url="/pages/about/index" hover-class="press-active">
      <view class="icon icon-info menu-icon"></view>
      <text class="menu-text">关于有数记小应用</text>
      <view class="icon icon-sm icon-arrow"></view>
    </view>
  </view>

  <!-- 3. 三合一登录抽屉 (Login Drawer Overlay) -->
  <view class="drawer-overlay" wx:if="{{showLoginDrawer}}" bindtap="closeLoginDrawer">
    <view class="drawer-panel" catchtap="preventBubble">
      <view class="drawer-header">
        <text class="drawer-title">云端账号同步管理</text>
        <view class="drawer-close-btn" bindtap="closeLoginDrawer">✕</view>
      </view>

      <!-- 登录选项卡 Tabs -->
      <view class="drawer-tabs">
        <view class="drawer-tab-item {{loginTab === 'wechat' ? 'active' : ''}}" bindtap="switchLoginTab" data-tab="wechat">
          微信快捷
        </view>
        <view class="drawer-tab-item {{loginTab === 'phone' ? 'active' : ''}}" bindtap="switchLoginTab" data-tab="phone">
          手机号登录
        </view>
        <view class="drawer-tab-item {{loginTab === 'email' ? 'active' : ''}}" bindtap="switchLoginTab" data-tab="email">
          邮箱登录
        </view>
      </view>

      <!-- 选项卡 1: 微信快捷登录 -->
      <view class="tab-content" wx:if="{{loginTab === 'wechat'}}">
        <view class="wechat-preview-box">
          <view class="icon icon-lg icon-wechat wechat-icon-hero"></view>
          <text class="login-tip">同步后，您的订阅数据可随时在微信云端进行安全备份与自动同步</text>
        </view>
        <button class="fluent-login-btn wechat-theme" bindtap="doWechatLogin" hover-class="press-active">
          <view class="icon icon-wechat-white wechat-btn-icon"></view>
          微信账号一键同步
        </button>
      </view>

      <!-- 选项卡 2: 手机验证码登录 -->
      <view class="tab-content" wx:if="{{loginTab === 'phone'}}">
        <view class="form-slot">
          <view class="input-row">
            <view class="icon icon-phone input-icon"></view>
            <input class="drawer-input" type="number" maxlength="11" placeholder="请输入手机号码" model:value="phoneNum" />
          </view>
          <view class="input-row">
            <view class="icon icon-lock input-icon"></view>
            <input class="drawer-input" type="number" maxlength="6" placeholder="请输入验证码" model:value="smsCode" />
            <text class="sms-send-btn {{smsCounting ? 'counting' : ''}}" bindtap="sendSmsCode">{{smsBtnText}}</text>
          </view>
        </view>
        <button class="fluent-login-btn" bindtap="doPhoneLogin" hover-class="press-active">
          验证并同步账号
        </button>
      </view>

      <!-- 选项卡 3: 邮箱密码登录 -->
      <view class="tab-content" wx:if="{{loginTab === 'email'}}">
        <view class="form-slot">
          <view class="input-row">
            <view class="icon icon-mail input-icon"></view>
            <input class="drawer-input" placeholder="请输入邮箱地址" model:value="emailAddr" />
          </view>
          <view class="input-row">
            <view class="icon icon-lock input-icon"></view>
            <input class="drawer-input" password="true" placeholder="请输入登录密码" model:value="emailPwd" />
          </view>
        </view>
        <button class="fluent-login-btn" bindtap="doEmailLogin" hover-class="press-active">
          账户密码同步
        </button>
      </view>

      <!-- 说明底部 -->
      <text class="drawer-footer-note">有数记严格遵循用户隐私协议保护您的账单数据安全</text>
    </view>
  </view>

</view>
