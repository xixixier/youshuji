/* pages/stat/stat.wxss — 有数记 · 数据分析美学版面 */

page {
  background-color: var(--color-canvas);
  padding-bottom: 180rpx;
}

.container {
  padding: 0;
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
}

/* ==========================================
   1. 艺术杂志式报告头 (Report Header)
   ========================================== */
.report-header {
  display: flex;
  flex-direction: column;
  padding: 48rpx var(--sp-lg);
  background-color: var(--color-surface);
  border-bottom: 1rpx solid var(--color-divider);
  width: 100%;
  box-sizing: border-box;
  position: relative;
}

.report-meta {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--color-accent);
  letter-spacing: 3rpx;
  text-transform: uppercase;
  margin-bottom: 12rpx;
  line-height: 1.2;
}

.report-title-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  width: 100%;
}

.report-title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 1rpx;
  line-height: 1.3;
}

.report-date {
  font-size: 22rpx;
  color: var(--color-text-3);
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

/* ==========================================
   2. 典雅数据看板格 (Metrics Panel)
   ========================================== */
.metrics-grid {
  display: flex;
  background-color: var(--color-surface);
  border-bottom: 1rpx solid var(--color-divider);
  padding: 48rpx var(--sp-lg);
  width: 100%;
  box-sizing: border-box;
  margin-bottom: var(--sp-md);
  position: relative;
}

.metric-cell {
  flex: 1.3;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.metric-label {
  font-size: 22rpx;
  color: var(--color-text-3);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.metric-value-wrap {
  display: flex;
  align-items: baseline;
  color: var(--color-primary);
  margin-bottom: var(--sp-xs);
}

.metric-currency {
  font-family: var(--font-serif);
  font-size: 44rpx;
  font-weight: 400;
  color: var(--color-accent);
  margin-right: 8rpx;
}

.metric-value {
  font-size: 72rpx;
  font-weight: 700;
  letter-spacing: -1.5rpx;
  line-height: 1;
}

.metric-footer {
  font-size: 20rpx;
  color: var(--color-text-3);
  font-weight: 600;
}

.metric-divider-y {
  width: 1rpx;
  background-color: var(--color-divider);
  margin: 0 var(--sp-lg);
}

.metric-cell-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.metric-sub-cell {
  display: flex;
  flex-direction: column;
}

.metric-sub-label {
  font-size: 20rpx;
  color: var(--color-text-3);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5rpx;
  margin-bottom: 4rpx;
}

.metric-sub-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-1);
}

.metric-divider-x {
  height: 1rpx;
  background-color: var(--color-divider);
  margin: var(--sp-xs) 0;
  width: 80%;
}

/* ==========================================
   3. 无框分栏导航键 (Command Bar)
   ========================================== */
.command-bar {
  display: flex;
  background-color: var(--color-surface);
  border-radius: var(--radius-md);
  margin: 0 var(--sp-lg) var(--sp-md);
  padding: 16rpx 0;
  box-shadow: 0 4px 16px rgba(28, 61, 50, 0.015);
  border: 1rpx solid rgba(28, 61, 50, 0.03);
}

.command-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--sp-xs) 0;
  position: relative;
}

.command-item::after {
  content: "";
  position: absolute;
  right: 0;
  top: 20%;
  height: 60%;
  width: 1rpx;
  background-color: var(--color-divider);
}

.command-item:last-child::after {
  display: none;
}

.command-item .icon {
  margin-bottom: 8rpx;
}

.command-text {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-text-3);
  letter-spacing: 1rpx;
}

.command-text.active {
  color: var(--color-primary);
  font-weight: 700;
}

.command-item.active {
  background-color: transparent;
}

/* ==========================================
   4. 精致刻度圆形图 (Donut Card Panel)
   ========================================== */
.donut-panel {
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  margin: 0 var(--sp-lg) var(--sp-md);
  padding: 44rpx var(--sp-lg);
  box-shadow: var(--shadow-organic);
  border: 1rpx solid rgba(28, 61, 50, 0.04);
  box-sizing: border-box;
}

.panel-head {
  margin-bottom: var(--sp-lg);
  text-align: center;
}

.panel-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 1rpx;
}

.panel-subtitle {
  font-size: 22rpx;
  color: var(--color-text-3);
  font-weight: 500;
  margin-top: var(--sp-xs);
  display: block;
}

.donut-chart-box {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: var(--sp-md) 0 var(--sp-lg);
}

.donut-wrap {
  position: relative;
  width: 320rpx;
  height: 320rpx;
}

.donut-canvas {
  width: 320rpx;
  height: 320rpx;
}

.donut-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 230rpx;
  height: 230rpx;
  background-color: var(--color-surface);
  border-radius: 50%;
  box-shadow: 0 4px 16px rgba(28, 61, 50, 0.03);
}

.donut-center-label {
  font-size: 18rpx;
  font-weight: 700;
  color: var(--color-text-3);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 2rpx;
}

.donut-center-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: -1rpx;
}

.donut-center-note {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--color-accent);
  margin-top: 2rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 180rpx;
}

/* 渐变指示条线 */
.composition-track {
  display: flex;
  height: 8rpx;
  background-color: var(--color-canvas);
  border-radius: var(--radius-pill);
  overflow: hidden;
  margin: var(--sp-md) 0;
}

.composition-segment {
  height: 100%;
}

.panel-footer-meta {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  color: var(--color-text-3);
  font-weight: 600;
  margin-top: var(--sp-xs);
  letter-spacing: 0.5rpx;
}

/* ==========================================
   5. 明细报表单 (Stats Detail Table)
   ========================================== */
.stats-list {
  display: flex;
  flex-direction: column;
  padding: 0 var(--sp-lg);
}

.section-title-wrap {
  margin: var(--sp-md) 0 var(--sp-sm);
}

.section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 1.5rpx;
  position: relative;
  padding-left: var(--sp-xs);
}

.section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 20%;
  height: 60%;
  width: 5rpx;
  background-color: var(--color-accent);
  border-radius: var(--radius-pill);
}

.stats-detail-rows {
  display: flex;
  flex-direction: column;
  background-color: var(--color-surface);
  border-radius: var(--radius-md);
  box-shadow: 0 4px 20px rgba(28, 61, 50, 0.015);
  border: 1rpx solid rgba(28, 61, 50, 0.03);
  overflow: hidden;
}

.stats-detail-row {
  display: flex;
  align-items: center;
  padding: 32rpx var(--sp-md);
  border-bottom: 1rpx solid var(--color-divider);
}

.stats-detail-row:last-child {
  border-bottom: none;
}

.detail-left {
  flex: 1.2;
  display: flex;
  align-items: center;
  min-width: 0;
}

.category-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.category-name-text {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text-1);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-center {
  flex: 1.5;
  display: flex;
  align-items: center;
  padding: 0 var(--sp-md);
}

.progress-track {
  flex: 1;
  height: 6rpx;
  background-color: var(--color-canvas);
  border-radius: var(--radius-pill);
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-bar {
  height: 100%;
  border-radius: var(--radius-pill);
}

.percentage-text {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--color-text-3);
  width: 68rpx;
  text-align: right;
}

.detail-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.amount-text {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.cycle-text {
  font-size: 18rpx;
  color: var(--color-text-3);
  font-weight: 500;
  margin-top: 2rpx;
}

/* ==========================================
   6. 缺省图 (Empty State)
   ========================================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: var(--color-surface);
  border: 1rpx solid rgba(28, 61, 50, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--sp-md);
}

.empty-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-2);
  margin-bottom: var(--sp-xs);
}

.empty-desc {
  font-size: 24rpx;
  color: var(--color-text-3);
  max-width: 320rpx;
  line-height: 1.5;
}
