/* pages/stat/stat.wxss */
page {
  background-color: var(--color-canvas);
  padding-bottom: 120rpx;
}

.container {
  padding: 0;
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
}

/* ==========================================
   1. Report Header
   ========================================== */
.report-header {
  display: flex;
  flex-direction: column;
  padding: var(--sp-lg);
  background-color: var(--color-surface);
  border-bottom: 1rpx solid var(--color-divider);
  width: 100%;
  box-sizing: border-box;
}

.report-meta {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--color-text-3);
  letter-spacing: 1rpx;
  text-transform: uppercase;
  line-height: 1.2;
  margin-bottom: var(--sp-xs);
}

.report-title-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  width: 100%;
}

.report-title {
  font-size: 38rpx;
  font-weight: 600;
  color: var(--color-text-1);
  line-height: 1.3;
}

.report-date {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 600;
}

/* ==========================================
   2. Metrics Grid
   ========================================== */
.metrics-grid {
  display: flex;
  background-color: var(--color-surface);
  border-bottom: 1rpx solid var(--color-divider);
  padding: var(--sp-xl) var(--sp-lg);
  width: 100%;
  box-sizing: border-box;
  margin-bottom: var(--sp-md);
}

.metric-cell {
  flex: 1.2;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.metric-label {
  font-size: 24rpx;
  color: var(--color-text-3);
  font-weight: 500;
  margin-bottom: var(--sp-sm);
}

.metric-value-wrap {
  display: flex;
  align-items: baseline;
  color: var(--color-text-1);
  margin-bottom: var(--sp-sm);
}

.metric-currency {
  font-size: 44rpx;
  font-weight: 500;
  margin-right: 6rpx;
  font-family: var(--font-mono);
}

.metric-value {
  font-size: 80rpx;
  font-weight: 700;
  font-family: var(--font-mono);
  letter-spacing: -2rpx;
  line-height: 1.1;
}

.metric-footer {
  font-size: 22rpx;
  color: var(--color-text-3);
  font-weight: 400;
}

.metric-divider-y {
  width: 1rpx;
  background-color: var(--color-divider-solid);
  margin: 0 var(--sp-lg);
  align-self: stretch;
}

.metric-cell-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.metric-sub-cell {
  display: flex;
  flex-direction: column;
  padding: 4rpx 0;
}

.metric-sub-label {
  font-size: 22rpx;
  color: var(--color-text-3);
  font-weight: 500;
  margin-bottom: 6rpx;
}

.metric-sub-value {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-1);
  font-family: var(--font-mono);
}

.metric-divider-x {
  height: 1rpx;
  background-color: var(--color-divider-solid);
  width: 100%;
}

/* ==========================================
   3. Command Bar
   ========================================== */
.command-bar {
  display: flex;
  background-color: var(--color-surface);
  border-bottom: 1rpx solid var(--color-divider);
  padding: var(--sp-md) 0;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: var(--sp-md);
}

.command-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--sp-xs);
  padding: var(--sp-xs) 0;
  border-radius: var(--radius-md);
  margin: 0 var(--sp-xs);
  transition: all 0.15s ease;
}

.command-item.active {
  background-color: var(--color-primary-mist);
}

.command-text {
  font-size: 24rpx;
  color: var(--color-text-2);
  font-weight: 500;
}

.command-text.active {
  color: var(--color-primary);
  font-weight: 700;
}

/* ==========================================
   4. Donut Panel
   ========================================== */
.donut-panel {
  background-color: var(--color-surface);
  border-top: 1rpx solid var(--color-divider);
  border-bottom: 1rpx solid var(--color-divider);
  padding: var(--sp-xl) var(--sp-lg);
  width: 100%;
  box-sizing: border-box;
  margin-bottom: var(--sp-md);
}

.panel-head {
  display: flex;
  flex-direction: column;
  gap: var(--sp-xs);
  margin-bottom: var(--sp-lg);
}

.panel-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-1);
  line-height: 1.4;
}

.panel-subtitle {
  font-size: 26rpx;
  color: var(--color-text-2);
  font-weight: 400;
  line-height: 1.5;
}

.donut-chart-box {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  margin-bottom: var(--sp-lg);
  position: relative;
}

.donut-wrap {
  width: 400rpx;
  height: 400rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.donut-canvas {
  width: 400rpx;
  height: 400rpx;
}

.donut-center {
  position: absolute;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background-color: var(--color-surface);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.donut-center-label {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--color-text-3);
  letter-spacing: 1rpx;
  text-transform: uppercase;
  line-height: 1.2;
  margin-bottom: var(--sp-xs);
}

.donut-center-value {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--color-text-1);
  font-family: var(--font-mono);
  line-height: 1.1;
  margin-bottom: var(--sp-xs);
}

.donut-center-note {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
  max-width: 220rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.composition-track {
  width: 100%;
  height: 8rpx;
  background-color: rgba(0, 0, 0, 0.03);
  border-radius: var(--radius-pill);
  overflow: hidden;
  display: flex;
  margin-bottom: var(--sp-sm);
}

.composition-segment {
  height: 100%;
  transition: width 1s cubic-bezier(0.1, 0.9, 0.2, 1);
}

.panel-footer-meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--color-text-3);
  font-weight: 500;
}

/* ==========================================
   5. Stats Detail List
   ========================================== */
.stats-list {
  background-color: var(--color-surface);
  border-top: 1rpx solid var(--color-divider);
  border-bottom: 1rpx solid var(--color-divider);
  width: 100%;
  box-sizing: border-box;
  padding: var(--sp-xl) 0 0;
}

.section-title-wrap {
  display: flex;
  padding: 0 var(--sp-lg);
  margin-bottom: var(--sp-md);
  width: 100%;
  box-sizing: border-box;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-1);
  line-height: 1.4;
}

.stats-detail-rows {
  display: flex;
  flex-direction: column;
}

.stats-detail-row {
  display: flex;
  align-items: center;
  padding: var(--sp-md) var(--sp-lg);
  border-bottom: 1rpx solid var(--color-divider);
}

.stats-detail-row:last-child {
  border-bottom: none;
}

/* Left: dot + name */
.detail-left {
  display: flex;
  align-items: center;
  gap: var(--sp-sm);
  min-width: 0;
  flex: 1;
}

.category-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.category-name-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-1);
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Center: progress + percentage */
.detail-center {
  display: flex;
  align-items: center;
  gap: var(--sp-sm);
  flex: 1.4;
  padding: 0 var(--sp-md);
}

.progress-track-line {
  flex: 1;
  height: 6rpx;
  background-color: rgba(0, 0, 0, 0.04);
  border-radius: var(--radius-pill);
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  border-radius: var(--radius-pill);
  transition: width 1s cubic-bezier(0.1, 0.9, 0.2, 1);
}

.progress-percentage-text {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-text-2);
  font-family: var(--font-mono);
  width: 72rpx;
  text-align: right;
  flex-shrink: 0;
}

/* Right: amount */
.detail-right {
  flex-shrink: 0;
  text-align: right;
}

.category-amount-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-1);
  font-family: var(--font-mono);
}

/* ==========================================
   6. Empty State
   ========================================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx var(--sp-xl);
  text-align: center;
}

.empty-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: var(--color-canvas);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--sp-md);
}

.empty-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-1);
  margin-bottom: var(--sp-xs);
}

.empty-subtitle {
  font-size: 24rpx;
  color: var(--color-text-3);
  font-weight: 400;
  margin-bottom: var(--sp-lg);
  max-width: 400rpx;
  line-height: 1.5;
}
