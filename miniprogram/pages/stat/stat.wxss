/* pages/stat/stat.wxss */
page {
  background-color: var(--fluent-bg);
  padding-bottom: 120rpx;
}

.container {
  padding: 0;
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
}

/* ==========================================
   1. 报表头部 (Minimalist Report Header)
   ========================================== */
.report-header {
  display: flex;
  flex-direction: column;
  padding: 32rpx;
  background-color: var(--fluent-surface);
  border-bottom: 1rpx solid var(--fluent-divider);
  width: 100%;
  box-sizing: border-box;
}

.report-meta {
  font-size: 18rpx;
  font-weight: 700;
  color: var(--fluent-text-mute);
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.report-title-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  width: 100%;
}

.report-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--fluent-text-main);
  letter-spacing: 0.5rpx;
}

.report-date {
  font-size: 22rpx;
  color: var(--fluent-primary);
  font-weight: 600;
}

/* ==========================================
   2. 网格化数据总览 (Microsoft Metrics Grid)
   ========================================== */
.metrics-grid {
  display: flex;
  background-color: var(--fluent-surface);
  border-bottom: 1rpx solid var(--fluent-divider);
  padding: 40rpx 32rpx;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.metric-cell {
  flex: 1.2;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.metric-label {
  font-size: 24rpx;
  color: var(--fluent-text-sec);
  font-weight: 500;
  margin-bottom: 12rpx;
}

.metric-value-wrap {
  display: flex;
  align-items: baseline;
  color: var(--fluent-text-main);
  margin-bottom: 12rpx;
}

.metric-currency {
  font-size: 40rpx;
  font-weight: 500;
  margin-right: 6rpx;
  font-family: var(--fluent-font-nums);
}

.metric-value {
  font-size: 64rpx;
  font-weight: 700;
  font-family: var(--fluent-font-nums);
  letter-spacing: -1rpx;
}

.metric-footer {
  font-size: 22rpx;
  color: var(--fluent-text-mute);
  font-weight: 400;
}

.metric-divider-y {
  width: 1rpx;
  background-color: var(--fluent-divider);
  margin: 0 40rpx;
  align-self: stretch;
}

.metric-cell-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.metric-sub-cell {
  display: flex;
  flex-direction: column;
  padding: 4rpx 0;
}

.metric-sub-label {
  font-size: 22rpx;
  color: var(--fluent-text-mute);
  font-weight: 500;
  margin-bottom: 6rpx;
}

.metric-sub-value {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--fluent-text-main);
  font-family: var(--fluent-font-nums);
}

.metric-divider-x {
  height: 1rpx;
  background-color: var(--fluent-divider);
  width: 100%;
}

/* ==========================================
   3. 命令条 (Fluent Command Bar)
   ========================================== */
.command-bar {
  display: flex;
  background-color: var(--fluent-surface);
  border-bottom: 1rpx solid var(--fluent-divider);
  padding: 24rpx 0;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.command-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-right: 1rpx solid var(--fluent-divider);
  transition: all 0.15s ease;
}

.command-item:last-child {
  border-right: none;
}

.command-item.active {
  background-color: #FAFDFC;
}

.command-text {
  font-size: 24rpx;
  color: var(--fluent-text-sec);
  font-weight: 500;
}

.command-text.active {
  color: var(--fluent-primary);
  font-weight: 700;
}

/* ==========================================
   4. 线宽高雅环形占比图 (Sophisticated Thin Doughnut Panel)
   ========================================== */
.donut-panel {
  background-color: var(--fluent-surface);
  border-top: 1rpx solid var(--fluent-divider);
  border-bottom: 1rpx solid var(--fluent-divider);
  padding: 40rpx 32rpx;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.panel-head {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 32rpx;
}

.panel-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--fluent-text-main);
  text-transform: uppercase;
}

.panel-subtitle {
  font-size: 22rpx;
  color: var(--fluent-text-sec);
  font-weight: 500;
}

.donut-chart-box {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  margin-bottom: 36rpx;
  position: relative;
}

.donut-wrap {
  width: 360rpx;
  height: 360rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.donut-canvas {
  width: 360rpx;
  height: 360rpx;
}

.donut-center {
  position: absolute;
  width: 250rpx;
  height: 250rpx;
  border-radius: 50%;
  background-color: var(--fluent-surface);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.donut-center-label {
  font-size: 20rpx;
  color: var(--fluent-text-mute);
  font-weight: 500;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 6rpx;
}

.donut-center-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--fluent-text-main);
  font-family: var(--fluent-font-nums);
  line-height: 1.1;
  margin-bottom: 6rpx;
}

.donut-center-note {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--fluent-primary);
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.composition-track {
  width: 100%;
  height: 10rpx; /* 极扁平，非常有设计感 */
  background-color: var(--fluent-divider);
  border-radius: 100rpx;
  overflow: hidden;
  display: flex;
  margin-bottom: 20rpx;
}

.composition-segment {
  height: 100%;
  transition: width 1s cubic-bezier(0.1, 0.9, 0.2, 1);
}

.panel-footer-meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--fluent-text-mute);
  font-weight: 500;
}

/* ==========================================
   5. Lists 风格分类明细报表
   ========================================== */
.stats-list {
  background-color: var(--fluent-surface);
  border-top: 1rpx solid var(--fluent-divider);
  border-bottom: 1rpx solid var(--fluent-divider);
  width: 100%;
  box-sizing: border-box;
  padding: 40rpx 0 0;
}

.section-title-wrap {
  display: flex;
  padding: 0 32rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--fluent-text-main);
  text-transform: uppercase;
}

.stats-table {
  display: flex;
  flex-direction: column;
}

/* 表头定义 */
.stats-table-header {
  display: flex;
  background-color: #FAF9F9;
  border-top: 1rpx solid var(--fluent-divider);
  border-bottom: 1rpx solid var(--fluent-divider);
  padding: 16rpx 32rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--fluent-text-mute);
  text-transform: uppercase;
}

.col-cat-name {
  flex: 1.2;
  min-width: 0;
}

.col-cat-progress {
  flex: 1.5;
}

.col-cat-amount {
  flex: 1;
  text-align: right;
}

/* 行样式 */
.stats-table-rows {
  display: flex;
  flex-direction: column;
}

.stats-table-row {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F3F3F3;
}

.stats-table-row:last-child {
  border-bottom: none;
}

.cell-cat-flex {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.category-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.category-name-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--fluent-text-main);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 进度槽布局 */
.progress-wrap-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-track-line {
  flex: 1;
  height: 6rpx; /* 极细线段，微软 Lists 感觉 */
  background-color: var(--fluent-divider);
  border-radius: 100rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 100rpx;
  transition: width 1s cubic-bezier(0.1, 0.9, 0.2, 1);
}

.progress-percentage-text {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--fluent-text-sec);
  font-family: var(--fluent-font-nums);
  width: 72rpx;
  text-align: right;
}

.category-amount-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--fluent-text-main);
  font-family: var(--fluent-font-nums);
}

/* 空状态 */
.lists-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 48rpx;
  text-align: center;
}

.empty-icon-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--fluent-text-main);
  margin-bottom: 8rpx;
}

.empty-subtitle {
  font-size: 24rpx;
  color: var(--fluent-text-mute);
  margin-bottom: 36rpx;
  max-width: 480rpx;
  line-height: 1.5;
}
