/* pages/index/index.wxss */
page {
  background-color: var(--fluent-bg);
  padding-bottom: 220rpx; /* 留出底部悬浮与Tab空间 */
}

.container {
  padding: 0;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  width: 100%;
}

/* ==========================================
   1. 顶部云端数据同步控制条 (Fluent Status Strip)
   ========================================== */
.sync-status-strip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 32rpx;
  background-color: var(--fluent-surface);
  border-bottom: 1rpx solid var(--fluent-divider);
  width: 100%;
  box-sizing: border-box;
  font-size: 24rpx;
  transition: all 0.25s ease;
}

.sync-status-strip.pending {
  border-left: 6rpx solid var(--fluent-text-mute);
}

.sync-status-strip.synced {
  border-left: 6rpx solid var(--fluent-primary);
  background-color: #FAFDFC;
}

.sync-status-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.sync-status-text {
  font-weight: 500;
  color: var(--fluent-text-sec);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sync-status-strip.synced .sync-status-text {
  color: var(--fluent-primary);
}

.sync-status-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.sync-action-btn {
  font-weight: 600;
  color: var(--fluent-primary);
  font-size: 24rpx;
}

.sync-status-strip.pending .sync-action-btn {
  color: var(--fluent-text-sec);
}

/* 同步图标转动动画 */
.rotating {
  animation: rotateSync 2s linear infinite;
}
@keyframes rotateSync {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ==========================================
   2. 网格化数字总览 (Microsoft Metrics Grid)
   ========================================== */
.metrics-grid {
  display: flex;
  background-color: var(--fluent-surface);
  border-bottom: 1rpx solid var(--fluent-divider);
  padding: 40rpx 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.metric-cell {
  flex: 1.2;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.metric-label {
  font-size: 24rpx;
  color: var(--fluent-text-sec);
  font-weight: 500;
  margin-bottom: 12rpx;
}

.metric-value-wrap {
  display: flex;
  align-items: baseline;
  color: var(--fluent-text-main);
  margin-bottom: 12rpx;
}

.metric-currency {
  font-size: 40rpx;
  font-weight: 500;
  margin-right: 6rpx;
  font-family: var(--fluent-font-nums);
}

.metric-value {
  font-size: 64rpx;
  font-weight: 700;
  font-family: var(--fluent-font-nums);
  letter-spacing: -1rpx;
}

.metric-footer {
  font-size: 22rpx;
  color: var(--fluent-text-mute);
  font-weight: 400;
}

.metric-divider-y {
  width: 1rpx;
  background-color: var(--fluent-divider);
  margin: 0 40rpx;
  align-self: stretch;
}

.metric-cell-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.metric-sub-cell {
  display: flex;
  flex-direction: column;
  padding: 4rpx 0;
}

.metric-sub-label {
  font-size: 22rpx;
  color: var(--fluent-text-mute);
  font-weight: 500;
  margin-bottom: 6rpx;
}

.metric-sub-value {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--fluent-text-main);
  font-family: var(--fluent-font-nums);
}

.metric-divider-x {
  height: 1rpx;
  background-color: var(--fluent-divider);
  width: 100%;
}

/* ==========================================
   3. 极平整工具条 (Minimalist Command Bar)
   ========================================== */
.command-bar {
  display: flex;
  background-color: var(--fluent-surface);
  border-bottom: 1rpx solid var(--fluent-divider);
  padding: 24rpx 0;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.command-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-right: 1rpx solid var(--fluent-divider);
  transition: all 0.15s ease;
}

.command-item:last-child {
  border-right: none;
}

.command-text {
  font-size: 24rpx;
  color: var(--fluent-text-sec);
  font-weight: 500;
}

/* ==========================================
   4. 即将续订日程栏 (Fluent Upcoming Timeline)
   ========================================== */
.section-title-wrap {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--fluent-text-main);
  letter-spacing: 0.5rpx;
  text-transform: uppercase;
}

.section-badge {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--fluent-text-mute);
  background-color: rgba(0, 0, 0, 0.05);
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
}

.upcoming-scroll {
  display: flex;
  flex-direction: row;
  width: 100%;
  white-space: nowrap;
  padding: 0 32rpx;
  box-sizing: border-box;
  margin-bottom: 36rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.upcoming-scroll::-webkit-scrollbar {
  display: none;
}

.upcoming-strip-card {
  display: inline-flex;
  flex-direction: column;
  justify-content: space-between;
  background-color: var(--fluent-surface);
  border: 1rpx solid var(--fluent-divider);
  border-radius: 12rpx;
  width: 290rpx;
  height: 190rpx;
  margin-right: 20rpx;
  padding: 24rpx;
  box-sizing: border-box;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.upcoming-strip-card.urgent {
  border: 1rpx solid rgba(216, 59, 1, 0.3);
  background-color: #FFFDFD;
}

.upcoming-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.app-avatar-circle {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background-color: #F3F4F6;
  color: var(--fluent-text-sec);
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.app-avatar-circle.urgent-bg {
  background-color: var(--fluent-danger-light);
  color: var(--fluent-danger);
}

.upcoming-tag-capsule {
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.upcoming-tag-capsule.normal {
  background-color: var(--fluent-primary-light);
  color: var(--fluent-primary);
}

.upcoming-tag-capsule.urgent {
  background-color: var(--fluent-danger-light);
  color: var(--fluent-danger);
}

.upcoming-card-bottom {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.upcoming-app-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--fluent-text-main);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.upcoming-app-price {
  font-size: 22rpx;
  color: var(--fluent-text-mute);
  font-family: var(--fluent-font-nums);
  font-weight: 500;
}

/* ==========================================
   5. 列表分类筛选 (Lists Column Header & Chips)
   ========================================== */
.lists-header-wrap {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.filter-capsules {
  display: flex;
  overflow-x: auto;
  gap: 16rpx;
  padding: 4rpx 32rpx 16rpx;
  width: 100%;
  box-sizing: border-box;
  -webkit-overflow-scrolling: touch;
}
.filter-capsules::-webkit-scrollbar {
  display: none;
}

.filter-chip {
  padding: 10rpx 28rpx;
  background-color: var(--fluent-surface);
  border: 1rpx solid var(--fluent-divider);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: var(--fluent-text-sec);
  font-weight: 500;
  white-space: nowrap;
  transition: all 0.15s ease;
}

.filter-chip.active {
  background-color: var(--fluent-primary);
  color: var(--fluent-surface);
  border-color: var(--fluent-primary);
}

/* ==========================================
   6. Excel/Lists 风格数据总表 (Minimalist Lists Table)
   ========================================== */
.lists-wrapper {
  background-color: var(--fluent-surface);
  border-top: 1rpx solid var(--fluent-divider);
  border-bottom: 1rpx solid var(--fluent-divider);
  width: 100%;
  box-sizing: border-box;
}

/* 表头定义 */
.lists-columns-title {
  display: flex;
  background-color: #FAF9F9;
  border-bottom: 1rpx solid var(--fluent-divider);
  padding: 16rpx 24rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--fluent-text-mute);
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.col-name {
  flex: 1.5;
  min-width: 0;
}

.col-category {
  flex: 1;
  text-align: center;
}

.col-price {
  flex: 1;
  text-align: right;
}

.col-date {
  flex: 1.2;
  text-align: right;
}

/* 行样式定义 */
.lists-rows {
  display: flex;
  flex-direction: column;
}

.list-row-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F3F3F3;
  transition: background-color 0.15s ease;
}

.list-row-item:last-child {
  border-bottom: none;
}

.list-row-item:active {
  background-color: #F8F9FA;
}

.cell-flex {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.list-char-circle {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: var(--fluent-primary-light);
  color: var(--fluent-primary);
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.list-app-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.list-app-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--fluent-text-main);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.list-app-sub {
  font-size: 20rpx;
  color: var(--fluent-text-mute);
  font-weight: 500;
}

.list-cell-badge {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--fluent-text-sec);
  background-color: #F3F4F6;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  display: inline-block;
}

.list-price-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--fluent-text-main);
  font-family: var(--fluent-font-nums);
}

.list-cycle-text {
  font-size: 20rpx;
  color: var(--fluent-text-mute);
}

.list-date-text {
  font-size: 24rpx;
  color: var(--fluent-text-sec);
  font-family: var(--fluent-font-nums);
  font-weight: 500;
  text-align: right;
}

/* 过期失效行灰度样式 */
.expired-row {
  opacity: 0.6;
  background-color: #FAF9F9;
}

.expired-circle {
  background-color: #EFEFEF;
  color: #8A8A8A;
}

.urgent-text {
  color: var(--fluent-danger);
  font-weight: 600;
}

/* 极简空状态 */
.lists-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 48rpx;
  text-align: center;
}

.empty-icon-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: #F3F4F6;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--fluent-text-main);
  margin-bottom: 8rpx;
}

.empty-subtitle {
  font-size: 24rpx;
  color: var(--fluent-text-mute);
  margin-bottom: 36rpx;
  max-width: 480rpx;
  line-height: 1.5;
}

.fluent-action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background-color: var(--fluent-primary);
  color: var(--fluent-surface);
  font-size: 26rpx;
  font-weight: 600;
  padding: 18rpx 40rpx;
  border-radius: 8rpx;
}

/* 微软扁平悬浮按钮 (FAB) */
.fluent-fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background-color: var(--fluent-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(16, 124, 65, 0.25);
  z-index: 99;
}

/* ==========================================
   7. 三合一高保真登录抽屉 (Login Drawer Overlay)
   ========================================== */
.drawer-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.drawer-panel {
  background-color: var(--fluent-surface);
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
  padding: 40rpx 40rpx 60rpx;
  width: 100%;
  box-sizing: border-box;
  animation: slideUp 0.3s cubic-bezier(0.1, 0.9, 0.2, 1);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.drawer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.drawer-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--fluent-text-main);
  letter-spacing: 0.5rpx;
}

.drawer-close-btn {
  font-size: 36rpx;
  color: var(--fluent-text-mute);
  padding: 10rpx;
}

/* Tab 切换栏 */
.drawer-tabs {
  display: flex;
  border-bottom: 2rpx solid var(--fluent-divider);
  margin-bottom: 40rpx;
}

.drawer-tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--fluent-text-mute);
  position: relative;
  transition: all 0.2s ease;
}

.drawer-tab-item.active {
  color: var(--fluent-primary);
  font-weight: 700;
}

.drawer-tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 30rpx;
  right: 30rpx;
  height: 4rpx;
  background-color: var(--fluent-primary);
  border-radius: 2rpx;
}

/* 登录内容区 */
.tab-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  animation: fadeIn 0.2s ease;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.wechat-preview-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  text-align: center;
}

.login-tip {
  font-size: 24rpx;
  color: var(--fluent-text-sec);
  line-height: 1.6;
  max-width: 500rpx;
}

.fluent-login-btn {
  width: 100% !important;
  background-color: var(--fluent-primary);
  color: var(--fluent-surface);
  font-size: 28rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.fluent-login-btn.wechat-theme {
  background-color: #07C160;
}

/* 表单插槽 */
.form-slot {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
  margin-bottom: 40rpx;
}

.input-row {
  display: flex;
  align-items: center;
  border: 1px solid var(--fluent-divider);
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  background-color: #FAF9F9;
  width: 100%;
  box-sizing: border-box;
}

.input-icon {
  margin-right: 16rpx;
}

.drawer-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--fluent-text-main);
  height: 48rpx;
}

.sms-send-btn {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--fluent-primary);
  background-color: var(--fluent-primary-light);
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
}

.sms-send-btn.counting {
  color: var(--fluent-text-mute);
  background-color: #EFEFEF;
}

.drawer-footer-note {
  font-size: 20rpx;
  color: var(--fluent-text-mute);
  text-align: center;
  margin-top: 32rpx;
}
