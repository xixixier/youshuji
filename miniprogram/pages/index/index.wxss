/* pages/index/index.wxss — 有数记 · 首页像素级样式 */
page {
  background-color: var(--color-canvas);
  padding-bottom: 200rpx;
}

.container {
  padding: 0;
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
}

/* ==========================================
   1. 流线型同步状态药丸 (Sleek Status Pill)
   ========================================== */
.status-pill {
  display: flex;
  align-items: center;
  margin: var(--sp-md) var(--sp-lg);
  padding: 0 var(--sp-md);
  height: 64rpx;
  border-radius: var(--radius-pill);
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-divider-solid);
  transition: all 0.2s ease;
}

.status-pill.synced {
  border-color: rgba(10, 92, 67, 0.12);
  background-color: rgba(10, 92, 67, 0.03);
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: var(--sp-sm);
  flex-shrink: 0;
}

.dot-idle {
  background-color: var(--color-text-3);
}

.dot-synced {
  background-color: var(--color-primary);
  animation: breathe 2.5s ease-in-out infinite;
}

@keyframes breathe {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

.status-label {
  flex: 1;
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-text-3);
  line-height: 1.2;
}

.status-pill.synced .status-label {
  color: var(--color-primary);
}

.status-action {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-right: var(--sp-xs);
}

.status-pill:not(.synced) .status-action {
  color: var(--color-text-2);
}

/* ==========================================
   2. 核心数据面板 (Hero Metrics Panel)
   ========================================== */
.metrics-panel {
  display: flex;
  align-items: stretch;
  background-color: var(--color-surface);
  border-top: 1rpx solid var(--color-divider-solid);
  border-bottom: 1rpx solid var(--color-divider-solid);
  padding: var(--sp-xl) var(--sp-lg);
  width: 100%;
  box-sizing: border-box;
}

.metric-hero {
  flex: 1.3;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.metric-hero-label {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-text-3);
  line-height: 1.2;
  margin-bottom: var(--sp-sm);
}

.metric-hero-row {
  display: flex;
  align-items: baseline;
  margin-bottom: var(--sp-sm);
}

.metric-hero-currency {
  font-size: 36rpx;
  font-weight: 500;
  color: var(--color-text-1);
  font-family: var(--font-mono);
  margin-right: 4rpx;
}

.metric-hero-amount {
  font-size: 72rpx;
  font-weight: 700;
  color: var(--color-text-1);
  font-family: var(--font-mono);
  letter-spacing: -2rpx;
  line-height: 1.1;
}

.metric-hero-footer {
  font-size: 20rpx;
  font-weight: 400;
  color: var(--color-text-3);
  line-height: 1.2;
}

.metric-side {
  flex: 0.8;
  display: flex;
  flex-direction: column;
  justify-content: center;
  margin-left: var(--sp-xl);
  padding-left: var(--sp-xl);
  border-left: 1rpx solid var(--color-divider-solid);
}

.metric-side-item {
  display: flex;
  flex-direction: column;
  gap: var(--sp-xs);
}

.metric-side-label {
  font-size: 20rpx;
  font-weight: 500;
  color: var(--color-text-3);
  line-height: 1.2;
}

.metric-side-value {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-1);
  font-family: var(--font-mono);
  line-height: 1.2;
}

.metric-side-divider {
  height: 1rpx;
  background-color: var(--color-divider);
  margin: var(--sp-sm) 0;
}

/* ==========================================
   3. 快捷操作栏 (Command Strip)
   ========================================== */
.cmd-strip {
  display: flex;
  background-color: var(--color-surface);
  border-bottom: 1rpx solid var(--color-divider-solid);
  padding: var(--sp-md) 0;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: var(--sp-md);
}

.cmd-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--sp-xs);
  transition: all 0.15s ease;
}

.cmd-text {
  font-size: 22rpx;
  color: var(--color-text-2);
  font-weight: 500;
  line-height: 1.2;
}

/* ==========================================
   4. 即将续订日程 (Upcoming Timeline)
   ========================================== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 var(--sp-lg);
  margin-bottom: var(--sp-sm);
  width: 100%;
  box-sizing: border-box;
}

.section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text-1);
  line-height: 1.4;
}

.section-count {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--color-text-3);
  background-color: rgba(0, 0, 0, 0.03);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-xs);
  line-height: 1.2;
}

.upcoming-scroll {
  display: flex;
  flex-direction: row;
  width: 100%;
  white-space: nowrap;
  padding: 0 var(--sp-lg);
  box-sizing: border-box;
  margin-bottom: var(--sp-xl);
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
.upcoming-scroll::-webkit-scrollbar { display: none; }

.upcoming-card {
  display: inline-flex;
  flex-direction: column;
  justify-content: space-between;
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-divider-solid);
  border-radius: var(--radius-md);
  width: 260rpx;
  height: 180rpx;
  margin-right: var(--sp-sm);
  padding: var(--sp-md);
  box-sizing: border-box;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.upcoming-card.urgent {
  border-left: 4rpx solid var(--color-danger);
  background-color: #FFFBFB;
}

.upcoming-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

/* 小头像 (用于 upcoming 卡片) */
.avatar-sm {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: var(--color-primary-soft);
  color: var(--color-primary);
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 48rpx;
}

.avatar-sm.avatar-danger {
  background-color: var(--color-danger-soft);
  color: var(--color-danger);
}

/* 标签胶囊 */
.tag-pill {
  font-size: 18rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-xs);
  line-height: 1.2;
}

.tag-normal {
  background-color: var(--color-primary-soft);
  color: var(--color-primary);
}

.tag-danger {
  background-color: var(--color-danger-soft);
  color: var(--color-danger);
}

.upcoming-bottom {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.upcoming-name {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-1);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.upcoming-price {
  font-size: 20rpx;
  color: var(--color-text-3);
  font-family: var(--font-mono);
  font-weight: 500;
  line-height: 1.2;
}

/* ==========================================
   5. 分类筛选胶囊 (Filter Chips)
   ========================================== */
.filter-scroll {
  display: flex;
  flex-direction: row;
  overflow-x: auto;
  gap: var(--sp-sm);
  padding: 4rpx var(--sp-lg) var(--sp-md);
  width: 100%;
  box-sizing: border-box;
  -webkit-overflow-scrolling: touch;
}
.filter-scroll::-webkit-scrollbar { display: none; }

.filter-chip {
  padding: var(--sp-xs) var(--sp-md);
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-divider-solid);
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  color: var(--color-text-2);
  font-weight: 500;
  white-space: nowrap;
  transition: all 0.15s ease;
  line-height: 1.4;
}

.filter-chip.active {
  background-color: var(--color-primary);
  color: #FFFFFF;
  border-color: var(--color-primary);
}

/* ==========================================
   6. 订阅列表 — 移动端纵向流式行 (Mobile Flow Rows)
   ========================================== */
.sub-list {
  background-color: var(--color-surface);
  border-top: 1rpx solid var(--color-divider-solid);
  border-bottom: 1rpx solid var(--color-divider-solid);
  width: 100%;
  box-sizing: border-box;
}

.sub-row {
  display: flex;
  align-items: center;
  padding: var(--sp-md) var(--sp-lg);
  border-bottom: 1rpx solid var(--color-divider);
  transition: background-color 0.15s ease;
}

.sub-row:last-child {
  border-bottom: none;
}

/* 中号头像 (列表行) */
.avatar-md {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: var(--color-primary-soft);
  color: var(--color-primary);
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  line-height: 60rpx;
  margin-right: var(--sp-sm);
}

.avatar-md.avatar-muted {
  background-color: var(--color-canvas);
  color: var(--color-text-3);
}

/* 中部信息区 */
.sub-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--sp-xs);
  min-width: 0;
}

.sub-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-1);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.4;
}

.sub-meta {
  display: flex;
  align-items: center;
  gap: var(--sp-xs);
}

.sub-badge {
  font-size: 18rpx;
  font-weight: 500;
  color: var(--color-text-2);
  background-color: rgba(0, 0, 0, 0.03);
  padding: 2rpx 10rpx;
  border-radius: var(--radius-xs);
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  line-height: 1.4;
}

.sub-type {
  font-size: 18rpx;
  font-weight: 400;
  color: var(--color-text-3);
  line-height: 1.4;
}

/* 右侧金额区 */
.sub-amount-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  flex-shrink: 0;
  margin-left: var(--sp-sm);
}

.sub-price {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-1);
  font-family: var(--font-mono);
  line-height: 1.3;
}

.sub-cycle {
  font-size: 20rpx;
  font-weight: 400;
  color: var(--color-text-3);
}

.sub-date {
  font-size: 20rpx;
  font-weight: 400;
  color: var(--color-text-3);
  font-family: var(--font-mono);
  line-height: 1.2;
}

.date-urgent {
  color: var(--color-danger);
  font-weight: 600;
}

/* 过期行 */
.row-expired {
  opacity: 0.5;
}

/* 空数据 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx var(--sp-xl);
  text-align: center;
}

.empty-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: var(--color-canvas);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--sp-md);
}

.empty-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-1);
  margin-bottom: var(--sp-xs);
  line-height: 1.4;
}

.empty-desc {
  font-size: 24rpx;
  color: var(--color-text-3);
  margin-bottom: var(--sp-xl);
  max-width: 400rpx;
  line-height: 1.5;
}

.btn-primary-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-primary);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  height: 80rpx;
  padding: 0 48rpx;
  border-radius: var(--radius-pill);
  line-height: 1;
}
.btn-primary-pill::after { border: none; }

/* 悬浮添加 FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
  box-shadow: 0 4rpx 16rpx rgba(10, 92, 67, 0.25);
}

/* ==========================================
   7. 三合一登录抽屉 (Login Drawer)
   ========================================== */
.drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(15, 23, 42, 0.4);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.drawer-body {
  background-color: var(--color-surface);
  border-top-left-radius: var(--radius-lg);
  border-top-right-radius: var(--radius-lg);
  padding: 40rpx 36rpx 60rpx;
  width: 100%;
  box-sizing: border-box;
  animation: slideUp 0.3s cubic-bezier(0.1, 0.9, 0.2, 1);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.drawer-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--sp-lg);
}

.drawer-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-1);
  line-height: 1.3;
}

.drawer-close {
  font-size: 32rpx;
  color: var(--color-text-3);
  padding: 10rpx;
  line-height: 1;
}

/* Tab 切换 */
.drawer-tabs {
  display: flex;
  border-bottom: 1rpx solid var(--color-divider-solid);
  margin-bottom: var(--sp-lg);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: var(--sp-sm) 0;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-3);
  position: relative;
  transition: all 0.2s ease;
  line-height: 1.4;
}

.tab-item.active {
  color: var(--color-primary);
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -1rpx;
  left: 30rpx;
  right: 30rpx;
  height: 3rpx;
  background-color: var(--color-primary);
  border-radius: 2rpx;
}

/* 登录内容 */
.tab-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  animation: fadeIn 0.2s ease;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.wx-promo {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--sp-xl) var(--sp-md);
  text-align: center;
}

.wx-tip {
  font-size: 24rpx;
  color: var(--color-text-2);
  line-height: 1.6;
  max-width: 460rpx;
}

.btn-wechat-pill {
  width: 100% !important;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-wechat);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  height: 92rpx;
  border-radius: var(--radius-pill);
  box-sizing: border-box;
  line-height: 1;
}
.btn-wechat-pill::after { border: none; }

/* 表单区 */
.form-fields {
  display: flex;
  flex-direction: column;
  gap: var(--sp-md);
  width: 100%;
  margin-bottom: var(--sp-lg);
}

.field-row {
  display: flex;
  align-items: center;
  background-color: var(--color-canvas);
  border: 1rpx solid var(--color-divider-solid);
  border-radius: var(--radius-sm);
  padding: var(--sp-sm) var(--sp-md);
  width: 100%;
  box-sizing: border-box;
}

.field-icon {
  margin-right: var(--sp-sm);
}

.field-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text-1);
  height: 48rpx;
  line-height: 48rpx;
}

.sms-btn {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-primary);
  background-color: var(--color-primary-soft);
  padding: var(--sp-xs) var(--sp-sm);
  border-radius: var(--radius-xs);
  white-space: nowrap;
  line-height: 1.2;
}

.sms-btn.sms-disabled {
  color: var(--color-text-3);
  background-color: rgba(0, 0, 0, 0.04);
}

.drawer-footer {
  font-size: 20rpx;
  color: var(--color-text-3);
  text-align: center;
  margin-top: var(--sp-lg);
  line-height: 1.4;
}
