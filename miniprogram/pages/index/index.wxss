/* pages/index/index.wxss — 有数记 · 首页高订生活美学版面 */

page {
  background-color: var(--color-canvas);
  padding-bottom: 220rpx; /* 留出充足底部避空 */
}

.container {
  padding: 0;
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
}

/* ==========================================
   1. 顶部空气感同步条 (Sleek Sync Bar)
   ========================================== */
.status-pill {
  display: flex;
  align-items: center;
  margin: var(--sp-md) var(--sp-lg) var(--sp-xs);
  padding: 0 var(--sp-md);
  height: 72rpx;
  border-radius: var(--radius-md);
  background-color: var(--color-surface);
  border: 1rpx solid rgba(28, 61, 50, 0.06);
  box-shadow: 0 4px 16px rgba(28, 61, 50, 0.01);
  transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.status-pill.synced {
  border-color: rgba(28, 61, 50, 0.12);
  background-color: rgba(28, 61, 50, 0.02);
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  margin-right: var(--sp-sm);
  flex-shrink: 0;
}

.dot-idle {
  background-color: var(--color-text-3);
}

.dot-synced {
  background-color: var(--color-primary);
  animation: breathe 3s ease-in-out infinite;
}

@keyframes breathe {
  0%, 100% { opacity: 0.9; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.85); }
}

.status-label {
  flex: 1;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-2);
  letter-spacing: 0.5rpx;
}

.status-pill.synced .status-label {
  color: var(--color-primary);
}

.status-action {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-accent);
  margin-right: var(--sp-xs);
}

.status-pill.synced .status-action {
  color: var(--color-primary);
}

/* ==========================================
   2. 高端画册式数据卡 (Hero Metrics Card)
   ========================================== */
.metrics-panel {
  display: flex;
  align-items: stretch;
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  margin: var(--sp-md) var(--sp-lg);
  padding: 48rpx 40rpx;
  box-sizing: border-box;
  box-shadow: var(--shadow-organic);
  border: 1rpx solid rgba(28, 61, 50, 0.04);
  position: relative;
  overflow: hidden;
}

/* 装饰背景，增添人文杂志氛围 */
.metrics-panel::after {
  content: "";
  position: absolute;
  top: 0;
  right: 0;
  width: 120rpx;
  height: 120rpx;
  background: radial-gradient(circle, var(--color-primary-soft) 0%, transparent 70%);
  opacity: 0.4;
  pointer-events: none;
}

.metric-hero {
  flex: 1.4;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.metric-hero-label {
  font-size: 22rpx;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 3rpx;
  color: var(--color-text-3);
  margin-bottom: var(--sp-xs);
}

.metric-hero-row {
  display: flex;
  align-items: baseline;
  margin: var(--sp-xs) 0;
}

.metric-hero-currency {
  font-family: var(--font-serif);
  font-size: 40rpx;
  font-weight: 400;
  color: var(--color-accent);
  margin-right: 6rpx;
}

.metric-hero-amount {
  font-size: 68rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: -1.5rpx;
  line-height: 1;
}

.metric-hero-footer {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--color-text-3);
  margin-top: var(--sp-xs);
  letter-spacing: 0.5rpx;
}

.metric-side {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-left: var(--sp-lg);
  border-left: 1rpx solid var(--color-divider);
}

.metric-side-item {
  display: flex;
  flex-direction: column;
  margin: var(--sp-xs) 0;
}

.metric-side-label {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--color-text-3);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 4rpx;
}

.metric-side-value {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--color-text-1);
  letter-spacing: -0.5rpx;
}

.metric-side-divider {
  height: 1rpx;
  background-color: var(--color-divider);
  margin: 12rpx 0;
  width: 60%;
}

/* ==========================================
   3. 高雅圆形操作板 (Command Strip)
   ========================================== */
.cmd-strip {
  display: flex;
  justify-content: space-between;
  margin: var(--sp-sm) var(--sp-lg);
  padding: var(--sp-md) var(--sp-sm);
  background-color: var(--color-surface);
  border-radius: var(--radius-md);
  box-shadow: 0 4px 20px rgba(28, 61, 50, 0.02);
  border: 1rpx solid rgba(28, 61, 50, 0.03);
}

.cmd-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.cmd-item::after {
  content: "";
  position: absolute;
  right: 0;
  top: 15%;
  height: 70%;
  width: 1rpx;
  background-color: var(--color-divider);
}

.cmd-item:last-child::after {
  display: none;
}

.cmd-item .icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 12rpx;
}

.cmd-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-2);
  letter-spacing: 1rpx;
}

/* ==========================================
   4. 人文手绘感日程卡 (Upcoming Timeline)
   ========================================== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin: var(--sp-lg) var(--sp-lg) var(--sp-sm);
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 1.5rpx;
  position: relative;
  padding-left: var(--sp-xs);
}

.section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 20%;
  height: 60%;
  width: 5rpx;
  background-color: var(--color-accent);
  border-radius: var(--radius-pill);
}

.section-count {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-text-3);
  letter-spacing: 0.5rpx;
}

.upcoming-scroll {
  display: flex;
  white-space: nowrap;
  width: 100%;
  box-sizing: border-box;
  padding: 0 var(--sp-lg);
  margin-bottom: var(--sp-xs);
}

.upcoming-card {
  display: inline-flex;
  flex-direction: column;
  justify-content: space-between;
  width: 260rpx;
  height: 180rpx;
  padding: 24rpx 28rpx;
  margin-right: 20rpx;
  background-color: var(--color-surface);
  border-radius: var(--radius-md);
  box-shadow: 0 4px 16px rgba(28, 61, 50, 0.02);
  border: 1rpx solid rgba(28, 61, 50, 0.05);
  box-sizing: border-box;
  flex-shrink: 0;
  transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.upcoming-card.urgent {
  background-color: var(--color-danger-soft);
  border-color: rgba(166, 64, 48, 0.12);
}

.upcoming-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.avatar-sm {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background-color: var(--color-primary-soft);
  color: var(--color-primary);
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-danger {
  background-color: rgba(166, 64, 48, 0.08);
  color: var(--color-danger);
}

.tag-pill {
  font-size: 18rpx;
  font-weight: 700;
  padding: 6rpx 14rpx;
  border-radius: var(--radius-pill);
  letter-spacing: 0.5rpx;
}

.tag-normal {
  background-color: var(--color-primary-soft);
  color: var(--color-primary);
}

.tag-danger {
  background-color: var(--color-danger);
  color: #FFFFFF;
}

.upcoming-bottom {
  display: flex;
  flex-direction: column;
  width: 100%;
}

.upcoming-name {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-text-1);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: 0.5rpx;
}

.upcoming-price {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--color-text-3);
  margin-top: 2rpx;
}

.upcoming-card.urgent .upcoming-price {
  color: var(--color-danger);
}

/* ==========================================
   5. 杂志选卡筛选槽 (Filter Section)
   ========================================== */
.filter-scroll {
  display: flex;
  white-space: nowrap;
  width: 100%;
  box-sizing: border-box;
  padding: var(--sp-xs) var(--sp-lg) var(--sp-md);
}

.filter-chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: var(--radius-pill);
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-2);
  background-color: var(--color-surface);
  border: 1rpx solid rgba(28, 61, 50, 0.06);
  box-shadow: 0 2px 8px rgba(28, 61, 50, 0.01);
  transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.filter-chip.active {
  background-color: var(--color-primary);
  color: #FFFFFF;
  border-color: var(--color-primary);
  box-shadow: 0 4px 12px rgba(28, 61, 50, 0.15);
}

/* ==========================================
   6. 典雅流式账簿列表 (Subscription Row List)
   ========================================== */
.sub-list {
  padding: 0 var(--sp-lg);
  display: flex;
  flex-direction: column;
}

.sub-row {
  display: flex;
  align-items: center;
  padding: 32rpx var(--sp-md);
  margin-bottom: 20rpx;
  background-color: var(--color-surface);
  border-radius: var(--radius-md);
  box-shadow: 0 4px 20px rgba(28, 61, 50, 0.015);
  border: 1rpx solid rgba(28, 61, 50, 0.04);
  box-sizing: border-box;
  position: relative;
  transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.sub-row::before {
  content: "";
  position: absolute;
  left: 0;
  top: 25%;
  height: 50%;
  width: 6rpx;
  background-color: var(--color-accent);
  border-top-right-radius: 4rpx;
  border-bottom-right-radius: 4rpx;
  opacity: 0.8;
}

.sub-row.row-expired {
  opacity: 0.6;
}

.sub-row.row-expired::before {
  background-color: var(--color-text-3);
}

.avatar-md {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background-color: var(--color-accent-soft);
  color: var(--color-accent);
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--sp-md);
  flex-shrink: 0;
}

.avatar-muted {
  background-color: #ECEAE5;
  color: var(--color-text-3);
}

.sub-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0; /* 防止文本溢出 */
}

.sub-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-1);
  letter-spacing: 0.5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sub-meta {
  display: flex;
  align-items: center;
  margin-top: 6rpx;
  flex-wrap: wrap;
}

.sub-badge {
  font-size: 18rpx;
  font-weight: 700;
  color: var(--color-primary);
  background-color: var(--color-primary-soft);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-xs);
  margin-right: 12rpx;
  text-transform: uppercase;
}

.sub-type {
  font-size: 18rpx;
  font-weight: 600;
  color: var(--color-text-3);
}

.sub-amount-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: var(--sp-md);
  flex-shrink: 0;
}

.sub-price {
  font-family: var(--font-sans);
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.sub-cycle {
  font-size: 20rpx;
  font-weight: 500;
  color: var(--color-text-3);
}

.sub-date {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--color-text-3);
  margin-top: 4rpx;
  letter-spacing: 0.5rpx;
}

.date-urgent {
  color: var(--color-danger);
}

/* ==========================================
   7. 空白占位状态 (Empty State)
   ========================================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background-color: var(--color-surface);
  border: 1rpx solid rgba(28, 61, 50, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--sp-md);
}

.empty-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-2);
  margin-bottom: var(--sp-xs);
  letter-spacing: 1rpx;
}

.empty-desc {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-3);
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.btn-primary-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-primary);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  height: 80rpx;
  padding: 0 48rpx;
  border-radius: var(--radius-pill);
  box-shadow: 0 8px 24px rgba(28, 61, 50, 0.15);
  letter-spacing: 1.5rpx;
}

/* ==========================================
   8. 悬浮精致加号按钮 (FAB)
   ========================================== */
.fab {
  position: fixed;
  right: var(--sp-lg);
  bottom: calc(148rpx + env(safe-area-inset-bottom));
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background-color: var(--color-primary);
  box-shadow: 0 12px 32px rgba(28, 61, 50, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
}

/* ==========================================
   9. 高订手持式登录抽屉 (Login Drawer Sheet)
   ========================================== */
.drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(25, 30, 28, 0.4);
  backdrop-filter: blur(8px);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.drawer-body {
  width: 100%;
  background-color: var(--color-surface);
  border-top-left-radius: var(--radius-lg);
  border-top-right-radius: var(--radius-lg);
  padding: 48rpx 40rpx 72rpx;
  box-sizing: border-box;
  animation: slideUp 0.3s cubic-bezier(0.25, 0.8, 0.25, 1) forwards;
  box-shadow: 0 -8px 32px rgba(28, 61, 50, 0.05);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.drawer-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--sp-lg);
}

.drawer-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 1.5rpx;
}

.drawer-close {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-3);
  padding: var(--sp-xs);
}

.drawer-tabs {
  display: flex;
  border-bottom: 1rpx solid var(--color-divider);
  margin-bottom: var(--sp-lg);
}

.tab-item {
  padding: 16rpx 0;
  margin-right: 48rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-3);
  position: relative;
}

.tab-item.active {
  color: var(--color-primary);
}

.tab-item.active::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: 0;
  width: 100%;
  height: 4rpx;
  background-color: var(--color-primary);
  border-radius: var(--radius-pill);
}

.tab-body {
  display: flex;
  flex-direction: column;
  margin-bottom: var(--sp-lg);
}

.wx-promo {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  text-align: center;
}

.wx-tip {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-2);
  line-height: 1.6;
  max-width: 480rpx;
}

.btn-wechat-pill {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-primary);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  height: 92rpx;
  border-radius: var(--radius-pill);
  box-shadow: 0 8px 24px rgba(28, 61, 50, 0.15);
  letter-spacing: 1.5rpx;
}

/* 表单输入域 */
.form-fields {
  display: flex;
  flex-direction: column;
  gap: var(--sp-md);
  margin-bottom: var(--sp-lg);
}

.field-row {
  display: flex;
  align-items: center;
  height: 92rpx;
  border-radius: var(--radius-sm);
  border: 1rpx solid var(--color-divider-solid);
  background-color: var(--color-canvas);
  padding: 0 var(--sp-md);
  box-sizing: border-box;
}

.field-icon {
  margin-right: var(--sp-sm);
}

.field-input {
  flex: 1;
  height: 100%;
  font-size: 26rpx;
  color: var(--color-text-1);
  font-weight: 600;
}

.sms-btn {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-accent);
  padding: var(--sp-xs) var(--sp-sm);
}

.sms-disabled {
  color: var(--color-text-3);
}

.drawer-footer {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: var(--color-text-3);
  letter-spacing: 0.5rpx;
}
