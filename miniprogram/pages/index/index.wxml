<!--index.wxml — 有数记 · 首页仪表盘-->
<view class="container">

  <!-- 1. 流线型同步状态药丸 (Sleek Status Pill) -->
  <view class="status-pill {{hasLogin ? 'synced' : ''}}" bindtap="triggerLoginAction" hover-class="press-active">
    <view class="status-dot {{hasLogin ? 'dot-synced' : 'dot-idle'}}"></view>
    <text class="status-label">{{hasLogin ? '云端已同步' : '尚未登录同步'}}</text>
    <text class="status-action">{{hasLogin ? '查看' : '登录'}}</text>
    <view class="icon icon-sm icon-arrow"></view>
  </view>

  <!-- 2. 核心数据面板 (Hero Metrics Panel) -->
  <view class="metrics-panel">
    <view class="metric-hero" bindtap="navigateToStat">
      <text class="metric-hero-label">本月支出</text>
      <view class="metric-hero-row">
        <text class="metric-hero-currency">¥</text>
        <text class="metric-hero-amount">{{totalMonthlyCost}}</text>
      </view>
      <text class="metric-hero-footer">年度预估 ¥{{yearlyEstimate}}</text>
    </view>
    <view class="metric-side">
      <view class="metric-side-item" bindtap="navigateToStat">
        <text class="metric-side-label">活跃订阅</text>
        <text class="metric-side-value">{{totalCount}}</text>
      </view>
      <view class="metric-side-divider"></view>
      <view class="metric-side-item" bindtap="navigateToStat">
        <text class="metric-side-label">日均消费</text>
        <text class="metric-side-value">¥{{dailyCost}}</text>
      </view>
    </view>
  </view>

  <!-- 3. 快捷操作栏 (Command Strip) -->
  <view class="cmd-strip">
    <view class="cmd-item" bindtap="navigateToAdd" hover-class="press-active">
      <view class="icon icon-plus"></view>
      <text class="cmd-text">添加</text>
    </view>
    <view class="cmd-item" bindtap="navigateToStat" hover-class="press-active">
      <view class="icon icon-stat"></view>
      <text class="cmd-text">分析</text>
    </view>
    <view class="cmd-item" bindtap="navigateToReminder" hover-class="press-active">
      <view class="icon icon-settings"></view>
      <text class="cmd-text">提醒</text>
    </view>
    <view class="cmd-item" bindtap="navigateToExport" hover-class="press-active">
      <view class="icon icon-backup"></view>
      <text class="cmd-text">导出</text>
    </view>
  </view>

  <!-- 4. 即将续订日程 (Upcoming Timeline) -->
  <block wx:if="{{upcomingSubscriptions.length > 0}}">
    <view class="section-header">
      <text class="section-title">临近续订</text>
      <text class="section-count">{{upcomingSubscriptions.length}} 笔</text>
    </view>
    <scroll-view class="upcoming-scroll" scroll-x="true" enable-flex="true">
      <block wx:for="{{upcomingSubscriptions}}" wx:key="_id">
        <view class="upcoming-card {{item.isUrgent ? 'urgent' : ''}}" bindtap="handleItemClick" data-id="{{item._id}}" data-name="{{item.appName}}" hover-class="press-active">
          <view class="upcoming-top">
            <view class="avatar-sm {{item.isUrgent ? 'avatar-danger' : ''}}">{{item.firstChar}}</view>
            <view class="tag-pill {{item.isUrgent ? 'tag-danger' : 'tag-normal'}}">{{item.daysRemainingText}}</view>
          </view>
          <view class="upcoming-bottom">
            <text class="upcoming-name">{{item.appName}}</text>
            <text class="upcoming-price">{{item.currency}}{{item.priceFixed}} / {{item.cycleCN}}</text>
          </view>
        </view>
      </block>
    </scroll-view>
  </block>

  <!-- 5. 分类筛选胶囊 (Filter Chips) -->
  <view class="section-header" style="margin-top: 8rpx;">
    <text class="section-title">全部订阅</text>
  </view>
  <scroll-view class="filter-scroll" scroll-x="true" enable-flex="true">
    <block wx:for="{{categories}}" wx:key="*this">
      <view class="filter-chip {{currentCategory === item ? 'active' : ''}}" bindtap="switchCategory" data-category="{{item}}" hover-class="press-active">
        {{item}}
      </view>
    </block>
  </scroll-view>

  <!-- 6. 订阅列表 — 移动端纵向流式行 (Mobile Flow Rows) -->
  <view class="sub-list">
    <block wx:for="{{subscriptions}}" wx:key="_id">
      <view class="sub-row {{item.isExpired ? 'row-expired' : ''}}" bindtap="handleItemClick" data-id="{{item._id}}" data-name="{{item.appName}}" hover-class="press-active">
        <!-- 左：首字母微标 -->
        <view class="avatar-md {{item.isExpired ? 'avatar-muted' : ''}}">{{item.firstChar}}</view>
        <!-- 中：名称 + 标签 -->
        <view class="sub-info">
          <text class="sub-name">{{item.appName}}</text>
          <view class="sub-meta">
            <text class="sub-badge">{{item.category || '其他'}}</text>
            <text class="sub-type">{{item.purchaseType === 'sub' ? '自动续订' : '买断'}}</text>
          </view>
        </view>
        <!-- 右：金额 + 日期 -->
        <view class="sub-amount-wrap">
          <text class="sub-price">{{item.currency}}{{item.priceFixed}}<text class="sub-cycle">/{{item.cycleCN}}</text></text>
          <text class="sub-date {{item.isUrgent && !item.isExpired ? 'date-urgent' : ''}}">{{item.isExpired ? '已失效' : item.formattedNextPayment}}</text>
        </view>
      </view>
    </block>

    <!-- 空数据 -->
    <view wx:if="{{subscriptions.length === 0}}" class="empty-state">
      <view class="empty-icon-wrap">
        <view class="icon icon-xl icon-sync-muted"></view>
      </view>
      <text class="empty-title">尚无订阅记录</text>
      <text class="empty-desc">轻触下方按钮，添加你的第一笔订阅</text>
      <button class="btn-primary-pill" bindtap="navigateToAdd" hover-class="press-active">
        <view class="icon icon-sm icon-plus-white" style="margin-right: 12rpx;"></view>
        添加订阅
      </button>
    </view>
  </view>

  <!-- 悬浮添加按钮 (FAB) -->
  <view wx:if="{{subscriptions.length > 0}}" class="fab" bindtap="navigateToAdd" hover-class="press-active">
    <view class="icon icon-plus-white"></view>
  </view>

  <!-- ===== 7. 三合一登录抽屉 (Login Drawer) ===== -->
  <view class="drawer-mask" wx:if="{{showLoginDrawer}}" bindtap="closeLoginDrawer">
    <view class="drawer-body" catchtap="preventBubble">
      <!-- 抽屉头部 -->
      <view class="drawer-head">
        <text class="drawer-title">账号登录</text>
        <view class="drawer-close" bindtap="closeLoginDrawer">✕</view>
      </view>

      <!-- 登录选项卡 -->
      <view class="drawer-tabs">
        <view class="tab-item {{loginTab === 'wechat' ? 'active' : ''}}" bindtap="switchLoginTab" data-tab="wechat">微信快捷</view>
        <view class="tab-item {{loginTab === 'phone' ? 'active' : ''}}" bindtap="switchLoginTab" data-tab="phone">手机号</view>
        <view class="tab-item {{loginTab === 'email' ? 'active' : ''}}" bindtap="switchLoginTab" data-tab="email">邮箱</view>
      </view>

      <!-- Tab 1: 微信 -->
      <view class="tab-body" wx:if="{{loginTab === 'wechat'}}">
        <view class="wx-promo">
          <view class="icon icon-xl icon-wechat" style="margin-bottom: 24rpx;"></view>
          <text class="wx-tip">授权微信账号后，订阅数据将安全同步至云端</text>
        </view>
        <button class="btn-wechat-pill" bindtap="doWechatLogin" hover-class="press-active">
          <view class="icon icon-sm icon-wechat-white" style="margin-right: 12rpx;"></view>
          微信一键登录
        </button>
      </view>

      <!-- Tab 2: 手机号 -->
      <view class="tab-body" wx:if="{{loginTab === 'phone'}}">
        <view class="form-fields">
          <view class="field-row">
            <view class="icon icon-phone field-icon"></view>
            <input class="field-input" type="number" maxlength="11" placeholder="请输入手机号码" model:value="phoneNum" />
          </view>
          <view class="field-row">
            <view class="icon icon-lock field-icon"></view>
            <input class="field-input" type="number" maxlength="6" placeholder="请输入验证码" model:value="smsCode" />
            <text class="sms-btn {{smsCounting ? 'sms-disabled' : ''}}" bindtap="sendSmsCode">{{smsBtnText}}</text>
          </view>
        </view>
        <button class="btn-primary-pill" bindtap="doPhoneLogin" hover-class="press-active">
          验证并登录
        </button>
      </view>

      <!-- Tab 3: 邮箱 -->
      <view class="tab-body" wx:if="{{loginTab === 'email'}}">
        <view class="form-fields">
          <view class="field-row">
            <view class="icon icon-mail field-icon"></view>
            <input class="field-input" placeholder="请输入邮箱地址" model:value="emailAddr" />
          </view>
          <view class="field-row">
            <view class="icon icon-lock field-icon"></view>
            <input class="field-input" password="true" placeholder="请输入登录密码" model:value="emailPwd" />
          </view>
        </view>
        <button class="btn-primary-pill" bindtap="doEmailLogin" hover-class="press-active">
          邮箱登录
        </button>
      </view>

      <text class="drawer-footer">有数记严格遵循隐私协议保护您的数据安全</text>
    </view>
  </view>

</view>
