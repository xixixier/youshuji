<!--pages/add/add.wxml — 有数记 · 新增账单-->
<view class="container">

  <!-- 表单头部 -->
  <view class="form-header">
    <text class="form-title">新增订阅账单</text>
    <text class="form-subtitle">添加一笔新的订阅或买断服务账目</text>
  </view>

  <!-- 表单内容主体 — 悬浮面板 -->
  <view class="fluent-form-panel">
    
    <!-- 1. 服务名称与智能匹配预览 -->
    <view class="form-row-item" style="height: auto; min-height: 112rpx; padding: 24rpx var(--sp-lg); flex-direction: column; align-items: flex-start; justify-content: center; gap: 12rpx;">
      <view style="display: flex; align-items: center; width: 100%;">
        <text class="form-row-label" style="margin-bottom: 0;">服务名称</text>
        <input class="form-row-input" model:value="{{appName}}" bindinput="onAppNameInput" placeholder="例如：Netflix, Spotify, iCloud" placeholder-style="color: var(--color-text-3);" />
      </view>
      
      <!-- 智能匹配到的官方徽章预览 -->
      <view class="brand-preview-pill" style="background-color: {{matchedBadge.brandColor || '#8C9691'}};" wx:if="{{matchedBadge || appName}}">
        <view class="brand-avatar-mini" style="background-image: url('{{iconPic}}'); background-size: contain; background-position: center; background-repeat: no-repeat; width: 36rpx; height: 36rpx;"></view>
        <text class="brand-name-text">{{matchedBadge ? '已智能匹配官方服务: ' + matchedBadge.name : '账单字首预览: ' + appName}}</text>
      </view>
    </view>
 
    <!-- 2. 账单制式分段切换 -->
    <view class="form-row-item">
      <text class="form-row-label">账单类型</text>
      <view class="segment-control">
        <view class="segment-item {{purchaseType === 'sub' ? 'active' : ''}}" bindtap="onPurchaseTypeChange" data-type="sub">订阅制</view>
        <view class="segment-item {{purchaseType === 'buyout' ? 'active' : ''}}" bindtap="onPurchaseTypeChange" data-type="buyout">买断制</view>
      </view>
    </view>
 
    <!-- 3. 动态分类选择 -->
    <view class="form-row-group">
      <text class="form-field-label">账单分类</text>
      <view class="category-grid">
        <block wx:for="{{categoriesWithSvg}}" wx:key="name">
          <view class="category-chip-item {{selectedCategory === item.name ? 'selected' : ''}}" bindtap="selectCategory" bindlongpress="deleteCategory" data-category="{{item.name}}">
            <view class="cat-circle-avatar" style="background-image: url('{{item.iconPic}}'); background-size: contain; background-position: center; background-repeat: no-repeat; width: 48rpx; height: 48rpx;"></view>
            <text class="cat-name">{{item.name}}</text>
          </view>
        </block>
        
        <!-- ➕ 新建自定义分类按钮 -->
        <view class="category-chip-item add-custom-chip" bindtap="showNewCategoryInput" hover-class="press-active">
          <view class="cat-circle-avatar" style="background-image: url('data:image/svg+xml;base64,PHN2ZyB2aWV3Qm94PScwIDAgMjQgMjQnIGZpbGw9J25vbmUnIHhtbG5zPSdodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2Zyc+PHBhdGggZD0nTTEyIDV2MTRNNSAxMmgxNCcgc3Ryb2tlPSclMjMxQzNEMzInIHN0cm9rZS13aWR0aD0nMicgc3Ryb2tlLWxpbmVjYXA9J3JvdW5kJy8+PC9zdmc+'); background-size: contain; background-position: center; background-repeat: no-repeat; width: 48rpx; height: 48rpx;"></view>
          <text class="cat-name">新建分类</text>
        </view>
      </view>
    </view>

    <!-- 4. 金额输入 -->
    <view class="form-row-item">
      <text class="form-row-label">账单金额 (¥)</text>
      <input class="form-row-input" type="digit" model:value="{{price}}" placeholder="0.00" placeholder-style="color: var(--color-text-3);" />
    </view>

    <!-- 5. 计费周期（仅订阅制显示） -->
    <view class="form-row-item" wx:if="{{purchaseType === 'sub'}}">
      <text class="form-row-label">扣款周期</text>
      <picker mode="selector" range="{{cycles}}" value="{{cycleIndex}}" bindchange="onCycleChange">
        <view class="picker-inner-row">
          <text class="picker-value-text">{{cycles[cycleIndex]}}</text>
          <view class="icon icon-sm icon-arrow"></view>
        </view>
      </picker>
    </view>

    <!-- 6. 扣款起始日/买断日期 -->
    <view class="form-row-item">
      <text class="form-row-label">{{purchaseType === 'sub' ? '扣款起始日' : '买断日期'}}</text>
      <picker mode="date" value="{{firstDate}}" bindchange="onDateChange">
        <view class="picker-inner-row">
          <text class="picker-value-text">{{firstDate || '请选择起始扣费日期'}}</text>
          <view class="icon icon-sm icon-arrow"></view>
        </view>
      </picker>
    </view>

    <!-- 7. 到期自动发送通知 Switch -->
    <view class="form-row-item">
      <text class="form-row-label" style="flex: 1;">到期自动发送服务通知</text>
      <switch checked="{{isRemind}}" bindchange="onRemindToggle" color="#1C3D32" />
    </view>

    <!-- 8. 说明备注 -->
    <view class="form-row-item" style="border-bottom: none;">
      <text class="form-row-label">备注说明</text>
      <input class="form-row-input" model:value="{{remark}}" placeholder="例如：由好友一同拼单/首月免费" placeholder-style="color: var(--color-text-3);" />
    </view>

  </view>

  <!-- 底部操作按钮 -->
  <view class="form-action-bar">
    <button class="primary-btn" bindtap="handleSave" hover-class="press-active">
      <view class="icon icon-sm icon-check-white" style="margin-right: 12rpx;"></view>
      保存账单记录
    </button>
  </view>

</view>
