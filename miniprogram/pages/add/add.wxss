/* pages/add/add.wxss */
page {
  background-color: var(--fluent-bg);
  padding-bottom: 220rpx;
}

.container {
  padding: 0;
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
}

/* ==========================================
   1. 表单头部 (Fluent Form Header)
   ========================================== */
.form-header {
  display: flex;
  flex-direction: column;
  padding: 36rpx 32rpx;
  background-color: var(--fluent-surface);
  border-bottom: 1rpx solid var(--fluent-divider);
  width: 100%;
  box-sizing: border-box;
}

.form-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--fluent-text-main);
  letter-spacing: 0.5rpx;
}

.form-subtitle {
  font-size: 22rpx;
  color: var(--fluent-text-mute);
  font-weight: 500;
  margin-top: 4rpx;
}

/* ==========================================
   2. 表单内容面板 (Fluent Form Panel)
   ========================================== */
.fluent-form-panel {
  background-color: var(--fluent-surface);
  border-bottom: 1rpx solid var(--fluent-divider);
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* 行组 (分类网格) */
.form-row-group {
  display: flex;
  flex-direction: column;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--fluent-divider);
  width: 100%;
  box-sizing: border-box;
}

.form-field-label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--fluent-text-sec);
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
  margin-bottom: 24rpx;
}

.category-grid {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  width: 100%;
  box-sizing: border-box;
  padding-bottom: 4rpx;
}
.category-grid::-webkit-scrollbar {
  display: none;
}

.category-chip-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 12rpx;
  background-color: #FAF9F9;
  border: 1rpx solid var(--fluent-divider);
  border-radius: 12rpx;
  width: 130rpx;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.cat-circle-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: var(--fluent-surface);
  color: var(--fluent-text-sec);
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--fluent-divider);
  transition: all 0.2s ease;
}

.cat-name {
  font-size: 20rpx;
  color: var(--fluent-text-sec);
  font-weight: 500;
}

/* 选中高亮状态 */
.category-chip-item.selected {
  background-color: var(--fluent-primary-light);
  border-color: var(--fluent-primary);
}

.category-chip-item.selected .cat-circle-avatar {
  background-color: var(--fluent-primary);
  color: var(--fluent-surface);
  border-color: var(--fluent-primary);
}

.category-chip-item.selected .cat-name {
  color: var(--fluent-primary);
  font-weight: 600;
}

/* 标准表单行 */
.form-row-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--fluent-divider);
  width: 100%;
  box-sizing: border-box;
}

.form-row-item:last-child {
  border-bottom: none;
}

.form-row-label {
  width: 200rpx;
  font-size: 26rpx;
  color: var(--fluent-text-sec);
  font-weight: 600;
  flex-shrink: 0;
}

.form-row-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--fluent-text-main);
  font-weight: 500;
}

/* Picker 包装行 */
picker {
  flex: 1;
  width: 100%;
}

.picker-inner-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.picker-value-text {
  font-size: 28rpx;
  color: var(--fluent-text-main);
  font-weight: 500;
}

/* ==========================================
   3. 底部命令条 (Fluent Form Action Bar)
   ========================================== */
.form-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: var(--fluent-surface);
  border-top: 1rpx solid var(--fluent-divider);
  padding: 36rpx 40rpx 48rpx;
  z-index: 99;
}

.fluent-primary-btn {
  width: 100% !important;
  background-color: var(--fluent-primary);
  color: var(--fluent-surface);
  font-size: 28rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.fluent-primary-btn::after {
  border: none;
}
