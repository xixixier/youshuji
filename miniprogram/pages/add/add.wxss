/* pages/add/add.wxss */
page {
  background-color: var(--color-canvas);
  padding-bottom: 200rpx;
}

.container {
  padding: 0;
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
}

/* ==========================================
   1. 表单头部
   ========================================== */
.form-header {
  display: flex;
  flex-direction: column;
  padding: var(--sp-xl) var(--sp-lg);
  background-color: var(--color-surface);
  border-bottom: 1rpx solid var(--color-divider-solid);
  width: 100%;
  box-sizing: border-box;
}

.form-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-1);
  line-height: 1.3;
}

.form-subtitle {
  font-size: 24rpx;
  font-weight: 400;
  color: var(--color-text-3);
  margin-top: var(--sp-xs);
}

/* ==========================================
   2. 表单内容面板
   ========================================== */
.fluent-form-panel {
  background-color: var(--color-surface);
  border-top: 1rpx solid var(--color-divider-solid);
  border-bottom: 1rpx solid var(--color-divider-solid);
  margin-top: var(--sp-xs);
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* 分类行组 */
.form-row-group {
  display: flex;
  flex-direction: column;
  padding: var(--sp-lg);
  border-bottom: 1rpx solid var(--color-divider);
  width: 100%;
  box-sizing: border-box;
}

.form-field-label {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--color-text-3);
  text-transform: uppercase;
  letter-spacing: 1rpx;
  line-height: 1.2;
  margin-bottom: var(--sp-md);
}

/* 分类网格 */
.category-grid {
  display: flex;
  gap: var(--sp-sm);
  overflow-x: auto;
  width: 100%;
  box-sizing: border-box;
  padding-bottom: var(--sp-xs);
}

.category-grid::-webkit-scrollbar {
  display: none;
}

.category-chip-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--sp-xs);
  padding: 20rpx 0;
  background-color: var(--color-surface);
  border: 1rpx solid var(--color-divider-solid);
  border-radius: var(--radius-md);
  width: 120rpx;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.cat-circle-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: var(--color-canvas);
  color: var(--color-text-2);
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--color-divider-solid);
  transition: all 0.2s ease;
}

.cat-name {
  font-size: 20rpx;
  color: var(--color-text-2);
  font-weight: 500;
}

/* 选中高亮状态 */
.category-chip-item.selected {
  background-color: var(--color-primary-soft);
  border-color: var(--color-primary);
}

.category-chip-item.selected .cat-circle-avatar {
  background-color: var(--color-primary);
  color: #FFFFFF;
  border-color: var(--color-primary);
}

.category-chip-item.selected .cat-name {
  color: var(--color-primary);
  font-weight: 600;
}

/* 标准表单行 */
.form-row-item {
  display: flex;
  align-items: center;
  padding: var(--sp-lg);
  border-bottom: 1rpx solid var(--color-divider);
  width: 100%;
  box-sizing: border-box;
}

.form-row-item:last-child {
  border-bottom: none;
}

.form-row-label {
  width: 180rpx;
  font-size: 26rpx;
  color: var(--color-text-2);
  font-weight: 500;
  flex-shrink: 0;
}

.form-row-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-1);
  font-weight: 500;
}

/* Picker 包装行 */
picker {
  flex: 1;
  width: 100%;
}

.picker-inner-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.picker-value-text {
  font-size: 28rpx;
  color: var(--color-text-1);
  font-weight: 500;
}

/* ==========================================
   3. 底部操作栏
   ========================================== */
.form-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: var(--color-surface);
  border-top: 1rpx solid var(--color-divider-solid);
  padding: 28rpx var(--sp-lg) 48rpx;
  z-index: 99;
}

.primary-btn {
  width: 100% !important;
  height: 92rpx;
  background-color: var(--color-primary);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary-btn::after {
  border: none;
}
