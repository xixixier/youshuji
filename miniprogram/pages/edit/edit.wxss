/* pages/edit/edit.wxss — 有数记 · 编辑账单高级版面 */

page {
  background-color: var(--color-canvas);
  padding-bottom: 240rpx; /* 底部预留按钮避空 */
}

.container {
  padding: 0;
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
}

/* ==========================================
   1. 艺术画册式表单头 (Form Header)
   ========================================== */
.form-header {
  display: flex;
  flex-direction: column;
  padding: 48rpx var(--sp-lg);
  background-color: var(--color-surface);
  border-bottom: 1rpx solid var(--color-divider);
  width: 100%;
  box-sizing: border-box;
}

.form-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 1rpx;
  line-height: 1.3;
}

.form-subtitle {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-3);
  margin-top: var(--sp-xs);
  letter-spacing: 0.5rpx;
}

/* ==========================================
   2. 悬浮典雅表单面板 (Floating Form Panel)
   ========================================== */
.fluent-form-panel {
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  margin: var(--sp-md) var(--sp-lg);
  box-shadow: var(--shadow-organic);
  border: 1rpx solid rgba(28, 61, 50, 0.04);
  width: auto;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 分类行组 */
.form-row-group {
  display: flex;
  flex-direction: column;
  padding: var(--sp-lg);
  border-bottom: 1rpx solid var(--color-divider);
  width: 100%;
  box-sizing: border-box;
}

.form-field-label {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--color-text-3);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: var(--sp-md);
  padding-left: 4rpx;
}

/* 分类水平滚动槽 */
.category-grid {
  display: flex;
  gap: var(--sp-sm);
  overflow-x: auto;
  width: 100%;
  box-sizing: border-box;
  padding-bottom: var(--sp-xs);
}

.category-grid::-webkit-scrollbar {
  display: none;
}

.category-chip-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--sp-xs);
  padding: 24rpx 0;
  background-color: var(--color-canvas);
  border: 1rpx solid rgba(28, 61, 50, 0.06);
  border-radius: var(--radius-md);
  width: 124rpx;
  flex-shrink: 0;
  transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
  box-shadow: 0 2px 8px rgba(28, 61, 50, 0.01);
}

.cat-circle-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background-color: var(--color-surface);
  color: var(--color-text-2);
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(28, 61, 50, 0.06);
  transition: all 0.2s ease;
}

.cat-name {
  font-size: 20rpx;
  color: var(--color-text-2);
  font-weight: 600;
  letter-spacing: 0.5rpx;
  transition: all 0.2s ease;
}

/* 选中高光状态 */
.category-chip-item.selected {
  background-color: var(--color-primary-soft);
  border-color: var(--color-primary);
  box-shadow: 0 4px 12px rgba(28, 61, 50, 0.04);
}

.category-chip-item.selected .cat-circle-avatar {
  background-color: var(--color-primary);
  color: #FFFFFF;
  border-color: var(--color-primary);
}

.category-chip-item.selected .cat-name {
  color: var(--color-primary);
  font-weight: 700;
}

/* 表单输入行项 */
.form-row-item {
  display: flex;
  align-items: center;
  padding: 0 var(--sp-lg);
  height: 112rpx;
  border-bottom: 1rpx solid var(--color-divider);
  box-sizing: border-box;
}

.form-row-item:last-child {
  border-bottom: none;
}

.form-row-label {
  width: 200rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-2);
  letter-spacing: 0.5rpx;
  flex-shrink: 0;
}

.form-row-input {
  flex: 1;
  height: 100%;
  font-size: 26rpx;
  color: var(--color-text-1);
  font-weight: 600;
}

/* 选择器美化 */
picker {
  flex: 1;
  height: 100%;
}

.picker-inner-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 112rpx;
  width: 100%;
  box-sizing: border-box;
}

.picker-value-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-1);
}

/* ==========================================
   3. 高雅浮置底部操作条 (Action Bar)
   ========================================== */
.form-action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--color-surface);
  border-top: 1rpx solid var(--color-divider-solid);
  padding: 32rpx var(--sp-lg) 56rpx;
  box-sizing: border-box;
  z-index: 99;
  box-shadow: 0 -8px 24px rgba(28, 61, 50, 0.02);
}

/* 按钮两栏布局 */
.flex-buttons {
  display: flex;
  gap: var(--sp-md);
  width: 100%;
}

.danger-btn {
  flex: 0.8;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-danger-soft) !important;
  color: var(--color-danger) !important;
  font-size: 26rpx !important;
  font-weight: 700 !important;
  height: 92rpx !important;
  border-radius: var(--radius-pill) !important;
  border: 1rpx solid rgba(166, 64, 48, 0.15) !important;
  letter-spacing: 1rpx !important;
  width: auto !important;
}

.primary-btn {
  flex: 1.2;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-primary) !important;
  color: #FFFFFF !important;
  font-size: 28rpx !important;
  font-weight: 700 !important;
  height: 92rpx !important;
  border-radius: var(--radius-pill) !important;
  box-shadow: 0 8px 24px rgba(28, 61, 50, 0.15) !important;
  letter-spacing: 2rpx !important;
  width: auto !important;
}
