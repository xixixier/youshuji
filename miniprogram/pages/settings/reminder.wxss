/* pages/settings/reminder.wxss — 有数记 · 提醒设置高订版面 */

page {
  background-color: var(--color-canvas);
  padding-bottom: 240rpx; /* 底部预留按钮避空 */
}

.container {
  padding: 0;
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
}

/* ==========================================
   1. 艺术画册式表单头 (Form Header)
   ========================================== */
.form-header {
  display: flex;
  flex-direction: column;
  padding: 48rpx var(--sp-lg);
  background-color: var(--color-surface);
  border-bottom: 1rpx solid var(--color-divider);
  width: 100%;
  box-sizing: border-box;
}

.form-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 1rpx;
  line-height: 1.3;
}

.form-subtitle {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-3);
  margin-top: var(--sp-xs);
  letter-spacing: 0.5rpx;
}

/* ==========================================
   2. 悬浮典雅表单面板 (Floating Form Panel)
   ========================================== */
.fluent-form-panel {
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  margin: var(--sp-md) var(--sp-lg);
  box-shadow: var(--shadow-organic);
  border: 1rpx solid rgba(28, 61, 50, 0.04);
  width: auto;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 分类行组 */
.form-row-group {
  display: flex;
  flex-direction: column;
  padding: var(--sp-lg);
  border-bottom: 1rpx solid var(--color-divider);
  width: 100%;
  box-sizing: border-box;
}

.form-field-label {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--color-text-3);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: var(--sp-md);
  padding-left: 4rpx;
}

/* 表单输入行项 */
.form-row-item {
  display: flex;
  align-items: center;
  padding: 0 var(--sp-lg);
  height: 112rpx;
  border-bottom: 1rpx solid var(--color-divider);
  box-sizing: border-box;
}

.form-row-item:last-child {
  border-bottom: none;
}

.form-row-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-2);
  letter-spacing: 0.5rpx;
}

/* 选择器美化 */
picker {
  flex: 1;
  height: 100%;
}

.picker-inner-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 112rpx;
  width: 100%;
  box-sizing: border-box;
}

.picker-value-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-1);
}

/* ==========================================
   3. 微信订阅授权版 (Message Subscription Box)
   ========================================== */
.subscribe-auth-box {
  display: flex;
  flex-direction: column;
  padding: var(--sp-xs) 0;
  width: 100%;
}

.auth-status-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.auth-status-text {
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
  letter-spacing: 0.5rpx;
}

.auth-status-text.authorized {
  color: var(--color-primary);
}

.auth-status-text.unauthorized {
  color: var(--color-text-3);
}

.auth-tip-text {
  font-size: 22rpx;
  color: var(--color-text-3);
  line-height: 1.6;
  margin-bottom: var(--sp-md);
  letter-spacing: 0.5rpx;
}

.auth-outline-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: transparent !important;
  color: var(--color-primary) !important;
  border: 1.5rpx solid var(--color-primary) !important;
  font-size: 26rpx !important;
  font-weight: 700 !important;
  height: 84rpx !important;
  border-radius: var(--radius-pill) !important;
  letter-spacing: 1.5rpx !important;
  width: 100% !important;
  transition: all 0.2s ease;
  box-shadow: 0 4px 12px rgba(28, 61, 50, 0.02);
}

/* ==========================================
   4. 高雅浮置底部操作条 (Action Bar)
   ========================================== */
.form-action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--color-surface);
  border-top: 1rpx solid var(--color-divider-solid);
  padding: 32rpx var(--sp-lg) 56rpx;
  box-sizing: border-box;
  z-index: 99;
  box-shadow: 0 -8px 24px rgba(28, 61, 50, 0.02);
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--color-primary) !important;
  color: #FFFFFF !important;
  font-size: 28rpx !important;
  font-weight: 700 !important;
  height: 92rpx !important;
  border-radius: var(--radius-pill) !important;
  box-shadow: 0 8px 24px rgba(28, 61, 50, 0.15) !important;
  letter-spacing: 2rpx !important;
  width: 100% !important;
}

/* ==========================================
   5. 提醒细分选项行项 (Fine-Grained Option Rows)
   ========================================== */
.setting-option-row {
  display: flex;
  align-items: center;
  height: 96rpx;
  border-bottom: 1rpx solid var(--color-divider);
  box-sizing: border-box;
  width: 100%;
}

.setting-option-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-2);
  letter-spacing: 0.5rpx;
}
