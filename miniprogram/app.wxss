/**
 * app.wxss — 有数记 · 高端生活美学与温暖人文主义（Premium Editorial & Neo-Humanist）
 * 设计原则：温和护眼、空气感留白、纤细发丝线、极致质感与排版一致性。
 */

/* ==========================================
   1. 高定视觉变量定义 (Luxury Design Tokens)
   ========================================== */
page {
  /* —— 护眼色彩架构 (Soothing Eyes Palette) —— */
  --color-canvas: #F8F7F4;          /* 温暖燕麦纸白（阻断蓝光，极致护眼） */
  --color-surface: #FFFFFF;         /* 纯净乳酪白容器 */
  --color-primary: #1C3D32;         /* 暮色松叶绿（沉稳高级的主体色） */
  --color-primary-soft: #EBF0EE;    /* 冷松绿浅雾（柔和高光） */
  --color-accent: #C2A582;          /* 温暖香槟金（高雅点缀色） */
  --color-accent-soft: #F6F2EB;     /* 香槟金软底 */
  --color-text-1: #191E1C;          /* 深灰曜石黑（柔和的主标题字） */
  --color-text-2: #4A524F;          /* 湿地青苔灰（优雅的阅读正文） */
  --color-text-3: #8C9691;          /* 晨雾石板灰（弱化元数据标签） */
  --color-danger: #A64030;          /* 温暖陶土红（警示色，克制而不刺眼） */
  --color-danger-soft: #FDF4F2;     /* 陶土红软底 */
  
  --color-wechat: #1C3D32;          /* 与微信统一，但融入松绿调 */
  --color-divider: rgba(28, 61, 50, 0.05); /* 超纤细发丝分割线 */
  --color-divider-solid: #EAE8E2;   /* 实线分割线 */

  /* —— 黄金网格间距系统 (Spacious Grid System) —— */
  --sp-xs: 8rpx;
  --sp-sm: 16rpx;
  --sp-md: 24rpx;
  --sp-lg: 32rpx;
  --sp-xl: 48rpx;
  --sp-xxl: 64rpx;

  /* —— 经典人文版式字体 (Soothing Typography) —— */
  --font-serif: Georgia, "Nimbus Roman No9 L", "Songti SC", "SimSun", serif;
  --font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  --font-mono: "Courier New", Courier, monospace, SFMono-Regular;

  /* —— 弧度与微立体 (Soft Radii & Atmosphere) —— */
  --radius-xs: 8rpx;
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-pill: 500rpx;

  /* —— 极致微阴影（呼吸感悬浮） —— */
  --shadow-organic: 0 8px 32px rgba(28, 61, 50, 0.03), 0 2px 8px rgba(0, 0, 0, 0.01);
  --shadow-active: 0 4px 12px rgba(28, 61, 50, 0.02);

  /* 全局基底重置 */
  background-color: var(--color-canvas);
  font-family: var(--font-sans);
  color: var(--color-text-1);
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

.container {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  width: 100%;
}

/* ==========================================
   2. 通用交互重置 (Reset & Animation)
   ========================================== */
button {
  background: initial;
  padding: 0;
  margin: 0;
  border-radius: 0;
  line-height: normal;
}
button::after {
  border: none;
}

/* 按钮微动按下态：慢速沉降，模拟气垫按压，无抖动 */
.press-active {
  opacity: 0.9;
  transform: scale(0.985);
  transition: all 0.15s cubic-bezier(0.25, 0.8, 0.25, 1);
}

/* ==========================================
   3. 高定纤细矢量 SVG 图标库 (Fine Line Iconset)
   ========================================== */
.icon {
  display: inline-block;
  width: 44rpx;
  height: 44rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
  vertical-align: middle;
  flex-shrink: 0;
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.icon-sm { width: 36rpx; height: 36rpx; }
.icon-lg { width: 52rpx; height: 52rpx; }
.icon-xl { width: 72rpx; height: 72rpx; }

