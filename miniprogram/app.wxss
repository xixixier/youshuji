/* ==========================================
   5. 全局通用骨架样式 (Universal Skeletons)
   ========================================== */

/* Fluent 设置列表 */
.fluent-list {
  background-color: var(--color-surface);
  border-top: 1rpx solid var(--color-divider-solid);
  border-bottom: 1rpx solid var(--color-divider-solid);
  width: 100%;
}

.fluent-item {
  display: flex;
  align-items: center;
  padding: var(--sp-lg) var(--sp-lg);
  border-bottom: 1rpx solid var(--color-divider);
  background-color: var(--color-surface);
  transition: background-color 0.15s ease;
}

.fluent-item:last-child {
  border-bottom: none;
}

.fluent-item:active {
  background-color: var(--color-canvas);
}

/* 通用文本修正 */
.text-right { text-align: right; }
