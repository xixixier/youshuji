/**app.wxss — 有数记 · 像素级全局设计系统 */

/* ==========================================
   1. 像素级设计变量 (Pixel-Perfect Design Tokens)
   ========================================== */
page {
  /* —— 精密色彩系统 (Color Architecture) —— */
  --color-canvas: #FAF9F6;          /* 粉垩砂白背景 */
  --color-surface: #FFFFFF;         /* 纯净白容器 */
  --color-primary: #0A5C43;         /* 曜岩翠绿（品牌色） */
  --color-primary-soft: #E8F5EE;    /* 淡翡翠背景 */
  --color-primary-mist: rgba(10, 92, 67, 0.06); /* 极淡翡翠雾 */
  --color-text-1: #0F172A;          /* 曜石极黑（主文字） */
  --color-text-2: #475569;          /* 板岩中灰（次级） */
  --color-text-3: #94A3B8;          /* 冷杉浅灰（弱化） */
  --color-danger: #B91C1C;          /* 绯红警示 */
  --color-danger-soft: #FEF2F2;     /* 淡绯红背景 */
  --color-wechat: #07C160;          /* 微信绿 */
  --color-divider: rgba(15, 23, 42, 0.04); /* 极淡分割线 */
  --color-divider-solid: #F1F0EE;   /* 实体分割线（用于需要精确控制处） */

  /* —— 黄金间距尺度 (Golden Spacing Scale) —— */
  --sp-xs: 8rpx;
  --sp-sm: 16rpx;
  --sp-md: 24rpx;
  --sp-lg: 32rpx;
  --sp-xl: 48rpx;

  /* —— 精密字体系统 (Typography) —— */
  --font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "PingFang SC", "Hiragino Sans GB", sans-serif;
  --font-mono: "Segoe UI", "SF Pro Display", -apple-system, monospace;

  /* —— 圆角系统 (Border Radius) —— */
  --radius-xs: 6rpx;
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-pill: 200rpx;

  /* 基础页面重置 */
  background-color: var(--color-canvas);
  font-family: var(--font-sans);
  color: var(--color-text-1);
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

.container {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  width: 100%;
}

/* ==========================================
   2. 全局元素重置 (Element Reset)
   ========================================== */
button {
  background: initial;
  padding: 0;
  margin: 0;
  border-radius: 0;
}
button::after {
  border: none;
}

/* ==========================================
   3. 微交互通用类 (Micro-interactions)
   ========================================== */
.press-active {
  transform: scale(0.97);
  opacity: 0.88;
}

/* ==========================================
   4. 统一 1.5px 精细矢量图标系统 (SVG Icon Library)
   ========================================== */
.icon {
  display: inline-block;
  width: 40rpx;
  height: 40rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
  vertical-align: middle;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.icon-sm { width: 32rpx; height: 32rpx; }
.icon-lg { width: 48rpx; height: 48rpx; }
.icon-xl { width: 64rpx; height: 64rpx; }

