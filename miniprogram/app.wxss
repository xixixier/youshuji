/**app.wxss**/

/* ==========================================
   1. Microsoft Fluent 全局设计变量与基线样式
   ========================================== */
page {
  /* 配色系统 - 微软扁平数据与生产力美学 */
  --fluent-bg: #F3F4F6;            /* 冷灰偏亮背景 */
  --fluent-surface: #FFFFFF;       /* 纯白容器面 */
  --fluent-text-main: #1F1F1F;     /* 微软深炭黑 - 主阅读字 */
  --fluent-text-sec: #505050;      /* 中度灰 - 辅助信息 */
  --fluent-text-mute: #8A8A8A;     /* 淡灰 - 元数据与占位符 */
  --fluent-divider: #EAEAEA;       /* 1px 极细分隔线色 */
  
  /* 品牌强调色 - 微软企业绿/数据绿 */
  --fluent-primary: #107C41;       /* 经典高雅 Excel 绿 - 代表“有数”与理财 */
  --fluent-primary-light: #E1F2E8; /* 浅绿背景 - 适用于徽章 */
  --fluent-danger: #D83B01;        /* 经典橙红 - 紧急/过期告警 */
  --fluent-danger-light: #FDE7E9;  /* 浅粉红背景 */

  /* 字体字重 - Tabular Nums 等宽数字确保账单对齐 */
  --fluent-font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "PingFang SC", sans-serif;
  --fluent-font-nums: "Segoe UI", "SF Pro Display", -apple-system, monospace;

  /* 基础页面重置 */
  background-color: var(--fluent-bg);
  font-family: var(--fluent-font);
  color: var(--fluent-text-main);
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

.container {
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  width: 100%;
}

button {
  background: initial;
  padding: 0;
  margin: 0;
  border-radius: 0;
}
button::after {
  border: none;
}
button:active {
  opacity: 0.85;
}

/* ==========================================
   2. 统一 1.5px 微软细线矢量图标系统 (CSS inline SVG)
   ========================================== */
.icon {
  display: inline-block;
  width: 40rpx;
  height: 40rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
  vertical-align: middle;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.icon-sm {
  width: 32rpx;
  height: 32rpx;
}

.icon-lg {
  width: 48rpx;
  height: 48rpx;
}

