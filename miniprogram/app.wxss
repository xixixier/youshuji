/* ==========================================
   3. 全局通用的高级扁平化骨架与列表样式 (Fluent Styles)
   ========================================== */

/* 主页、统计页的列表项分割样式 */
.fluent-list {
  background-color: var(--fluent-surface);
  border-top: 1rpx solid var(--fluent-divider);
  border-bottom: 1rpx solid var(--fluent-divider);
  width: 100%;
}

.fluent-item {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid var(--fluent-divider);
  background-color: var(--fluent-surface);
  transition: background-color 0.15s ease;
}

.fluent-item:last-child {
  border-bottom: none;
}

.fluent-item:active {
  background-color: #F8F9FA;
}

/* 触点按压轻微收缩回弹动画 */
.fluent-btn-active {
  transform: scale(0.98);
  opacity: 0.9;
}
